# ============================================
# GENFEED.AI CANONICAL ENV TEMPLATE
# ============================================
# Copy this file to one of:
# - .env.local        for local development
# - .env.staging      for staging deployments
# - .env.production   for production deployments
#
# Then generate app/service env files with:
#   bun run env:sync local --prune-legacy
#   bun run env:sync staging
#   bun run env:sync production
#
# Root env files are the only source of truth.
# App and service .env files are generated outputs.
# ============================================

# --------------------------------------------
# Shared Runtime
# --------------------------------------------
NODE_ENV=development
REDIS_URL=redis://localhost:6379
MONGODB_URI=mongodb://localhost:27017/genfeed

# --------------------------------------------
# Shared URLs
# --------------------------------------------
API_URL=http://local.genfeed.ai:3001
GENFEEDAI_API_URL=http://local.genfeed.ai:3001
GENFEEDAI_APP_URL=http://local.genfeed.ai:3102
GENFEEDAI_PUBLIC_URL=http://local.genfeed.ai:3105
GENFEEDAI_CDN_URL=https://staging-cdn.genfeed.ai
GENFEEDAI_MICROSERVICES_FILES_URL=http://local.genfeed.ai:3005
GENFEEDAI_MICROSERVICES_MCP_URL=http://local.genfeed.ai:3006
GENFEEDAI_MICROSERVICES_NOTIFICATIONS_URL=http://local.genfeed.ai:3007
GENFEEDAI_WEBHOOKS_URL=https://your-ngrok-url.ngrok-free.app
GENFEEDAI_API_KEY=

# --------------------------------------------
# Shared Auth / Edition
# --------------------------------------------
CLERK_SECRET_KEY=sk_test_your_secret_key
