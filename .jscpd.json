{
  "absolute": true,
  "format": ["typescript", "typescriptjsx"],
  "ignore": [
    "node_modules",
    "**/node_modules/**",
    ".next",
    "**/.next/**",
    "dist",
    "**/dist/**",
    "build",
    "**/build/**",
    ".turbo",
    "**/.turbo/**",
    "coverage",
    "**/coverage/**",
    "storybook-static",
    "**/storybook-static/**",
    ".agents",
    "**/.agents/**",
    ".claude",
    "**/.claude/**",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.d.ts",
    "**/bun.lock",
    "**/*.json",
    "**/*.scss",
    "**/*.css"
  ],
  "minLines": 30,
  "minTokens": 50,
  "threshold": 0
}
