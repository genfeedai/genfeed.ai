{
  "$schema": "https://biomejs.dev/schemas/2.4.16/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/node_modules",
      "!**/.next",
      "!**/.turbo",
      "!**/dist",
      "!**/build",
      "!**/out",
      "!**/coverage",
      "!**/.plasmo",
      "!**/.plasmo",
      "!**/test-results",
      "!**/playwright/artifacts",
      "!**/playwright-report",
      "!**/playwright-results",
      "!**/*.snap",
      "!**/generated",
      "!**/bun.lock",
      "!**/.env",
      "!**/.env.*",
      "!**/next-env.d.ts",
      "!**/.agents",
      "!**/.agents",
      "!.agents",
      "!.worktrees",
      "!.shipcode",
      "!.clawpatch"
    ]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    },
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "a11y": {
        "noLabelWithoutControl": "off"
      },
      "recommended": true
    }
  },
  "overrides": [
    {
      "includes": ["apps/app/src/features/workflows/**"],
      "linter": {
        "rules": {
          "a11y": {
            "noLabelWithoutControl": "off",
            "noSvgWithoutTitle": "off",
            "useSemanticElements": "off"
          },
          "complexity": {
            "noUselessSwitchCase": "off"
          },
          "correctness": {
            "noUnusedFunctionParameters": "off",
            "noUnusedVariables": "off"
          },
          "performance": {
            "noImgElement": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          },
          "suspicious": {
            "noArrayIndexKey": "off",
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/server/**", "packages/libs/**"],
      "javascript": {
        "parser": {
          "unsafeParameterDecoratorsEnabled": true
        }
      },
      "linter": {
        "rules": {
          "style": {
            "useImportType": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/server/notifications/**/*.ts"],
      "linter": {
        "rules": {
          "suspicious": {
            "noExplicitAny": "error"
          }
        }
      }
    },
    {
      "includes": ["apps/server/api/src/collections/agent-goals/**/*.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "error"
          }
        }
      }
    },
    {
      "includes": ["apps/server/api/src/collections/assets/**/*.ts"],
      "linter": {
        "rules": {
          "correctness": {
            "noUnusedImports": "error"
          }
        }
      }
    },
    {
      "includes": [
        "ee/packages/**/*.{controller,service,module,resolver,guard,interceptor,pipe,middleware,filter}.ts"
      ],
      "javascript": {
        "parser": {
          "unsafeParameterDecoratorsEnabled": true
        }
      },
      "linter": {
        "rules": {
          "style": {
            "useImportType": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/app/src/components/**",
        "apps/app/src/hooks/**",
        "apps/desktop/app/src/renderer/views/**",
        "packages/agent/src/**",
        "packages/hooks/**",
        "packages/pages/**",
        "packages/ui/src/components/**",
        "packages/workflows/src/ui/**"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "noLabelWithoutControl": "off",
            "noStaticElementInteractions": "off",
            "noSvgWithoutTitle": "off",
            "useButtonType": "off",
            "useKeyWithClickEvents": "off",
            "useMediaCaption": "warn",
            "useSemanticElements": "off",
            "useValidAriaRole": "off"
          },
          "complexity": {
            "noBannedTypes": "warn"
          },
          "correctness": {
            "noChildrenProp": "warn",
            "noUnusedFunctionParameters": "warn",
            "noUnusedVariables": "warn",
            "useExhaustiveDependencies": "warn",
            "useHookAtTopLevel": "warn"
          },
          "performance": {
            "noImgElement": "off"
          },
          "security": {
            "noDangerouslySetInnerHtml": "warn"
          },
          "style": {
            "noNonNullAssertion": "warn"
          },
          "suspicious": {
            "noArrayIndexKey": "off",
            "noExplicitAny": "off",
            "noImplicitAnyLet": "warn",
            "noShadowRestrictedNames": "warn",
            "useIterableCallbackReturn": "warn"
          }
        }
      }
    },
    {
      "includes": ["apps/server/api/src/**"],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "paths": {
                  "@nestjs/common": {
                    "importNames": ["NotFoundException"],
                    "message": "Use the JSON:API NotFoundException from @api/helpers/exceptions/http/not-found.exception instead of the @nestjs/common built-in (audit C2c: one 404 shape)."
                  }
                }
              }
            }
          }
        }
      }
    }
  ]
}
