{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "all"
    },
    "parser": {
      "unsafeParameterDecoratorsEnabled": true
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "a11y": {
        "noLabelWithoutControl": "off"
      },
      "recommended": true
    }
  },
  "overrides": [
    {
      "includes": ["apps/app/src/features/workflows/**"],
      "linter": {
        "rules": {
          "a11y": {
            "noLabelWithoutControl": "off",
            "noSvgWithoutTitle": "off",
            "useSemanticElements": "off"
          },
          "complexity": {
            "noUselessSwitchCase": "off"
          },
          "correctness": {
            "noUnusedFunctionParameters": "off",
            "noUnusedVariables": "off"
          },
          "performance": {
            "noImgElement": "off"
          },
          "style": {
            "noNonNullAssertion": "off"
          },
          "suspicious": {
            "noArrayIndexKey": "off",
            "noExplicitAny": "off"
          }
        }
      }
    },
    {
      "includes": ["apps/server/**"],
      "javascript": {
        "parser": {
          "unsafeParameterDecoratorsEnabled": true
        }
      },
      "linter": {
        "enabled": false
      }
    },
    {
      "includes": [
        "apps/app/src/components/**",
        "apps/app/src/hooks/**",
        "packages/agent/src/**",
        "packages/hooks/**",
        "packages/pages/**"
      ],
      "linter": {
        "rules": {
          "a11y": {
            "noLabelWithoutControl": "off",
            "noStaticElementInteractions": "off",
            "noSvgWithoutTitle": "off",
            "useButtonType": "off",
            "useKeyWithClickEvents": "off",
            "useSemanticElements": "off",
            "useValidAriaRole": "off"
          },
          "correctness": {
            "useExhaustiveDependencies": "warn"
          },
          "performance": {
            "noImgElement": "off"
          },
          "suspicious": {
            "noArrayIndexKey": "off",
            "noExplicitAny": "off"
          }
        }
      }
    }
  ]
}
