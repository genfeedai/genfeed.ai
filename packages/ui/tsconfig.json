{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSources": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "paths": {
      "@genfeedai/contexts": ["../contexts/index.ts"],
      "@genfeedai/contexts/*": ["../contexts/*"],
      "@genfeedai/helpers": ["../helpers/src/index.ts"],
      "@genfeedai/helpers/*": ["../helpers/src/*"],
      "@genfeedai/hooks": ["../hooks/index.ts"],
      "@genfeedai/hooks/*": ["../hooks/*"],
      "@genfeedai/models": ["../models/index.ts"],
      "@genfeedai/models/*": ["../models/*"],
      "@genfeedai/props": ["../props/index.ts"],
      "@genfeedai/props/*": ["../props/*"],
      "@genfeedai/providers": ["../contexts/providers"],
      "@genfeedai/providers/*": ["../contexts/providers/*"],
      "@genfeedai/services": ["../services/index.ts"],
      "@genfeedai/services/*": ["../services/*"],
      "@genfeedai/ui/*": ["./src/*"],
      "@genfeedai/utils": ["../utils/index.ts"],
      "@genfeedai/utils/*": ["../utils/*"],
      "@ui/*": ["./src/*"]
    },
    "rootDir": "./src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2022"
  },
  "exclude": [
    "node_modules",
    "dist",
    "src/components",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.test.ts",
    "**/*.test.tsx"
  ],
  "include": ["src/**/*.d.ts", "src/**/*.ts", "src/**/*.tsx"],
  "references": [
    {
      "path": "../client"
    },
    {
      "path": "../enums"
    },
    {
      "path": "../interfaces"
    }
  ]
}
