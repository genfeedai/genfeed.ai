{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "inlineSources": true,
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "paths": {
      "@genfeedai/constants": ["../constants/src/index.ts"],
      "@genfeedai/constants/*": ["../constants/src/*"],
      "@genfeedai/serializers": ["../serializers/src/index.ts"],
      "@genfeedai/serializers/*": ["../serializers/src/*"],
      "@genfeedai/enums": ["../enums/src/index.ts"],
      "@genfeedai/enums/*": ["../enums/src/*"],
      "@genfeedai/helpers/*": ["./src/*"],
      "@genfeedai/interfaces": ["../interfaces/src/index.ts"],
      "@genfeedai/interfaces/*": ["../interfaces/src/*"],
      "@helpers/*": ["./src/*"],
      "@hooks/*": ["../hooks/*"],
      "@utils/*": ["../utils/*"]
    },
    "rootDir": "./src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2022"
  },
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/voice-commands.helper.ts",
    "src/voice/**",
    "src/media/download/download.helper.ts"
  ],
  "include": ["src/**/*.ts"],
  "references": [
    {
      "path": "../constants"
    },
    {
      "path": "../enums"
    },
    {
      "path": "../interfaces"
    }
  ]
}
