{
  "dependencies": {
    "@genfeedai/constants": "workspace:*",
    "@genfeedai/enums": "workspace:*",
    "@genfeedai/interfaces": "workspace:*",
    "clsx": "2.1.1",
    "tailwind-merge": "3.5.0",
    "ts-jsonapi": "2.1.3"
  },
  "description": "Shared helpers for Genfeed clients and services",
  "devDependencies": {
    "@types/file-saver": "2.0.7",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "date-fns": "4.1.0",
    "file-saver": "2.0.5",
    "next": "16.2.3",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "7.72.1",
    "react-icons": "5.6.0",
    "typescript": "6.0.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/index.ts",
    "src/aspect-ratio.helper.ts",
    "src/business/pricing/pricing.helper.ts",
    "src/business/tier-models/tier-models.helper.ts",
    "src/deserializer.helper.ts",
    "src/model-capability.helper.ts",
    "src/quality-routing.helper.ts",
    "src/serializer.helper.ts",
    "src/social-url.helper.ts",
    "src/types/model-like.type.ts",
    "src/video-duration.helper.ts"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "name": "@genfeedai/helpers",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "directory": "helpers",
    "type": "git",
    "url": "git+https://github.com/genfeedai/packages.git"
  },
  "scripts": {
    "build": "rm -rf dist tsconfig.tsbuildinfo && tsc --build --force && if [ -d dist/src ]; then mv dist/src/* dist/ 2>/dev/null && rm -rf dist/src; fi",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "deps:update": "bunx npm-check-updates -u && bun install",
    "dev": "tsc --watch",
    "prepublishOnly": "bun run build",
    "test": "vitest run --config vitest.config.ts",
    "test:cov": "vitest run --coverage --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:watch": "vitest watch --config vitest.config.ts",
    "type-check": "tsc --noEmit"
  },
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "version": "2.2.12"
}
