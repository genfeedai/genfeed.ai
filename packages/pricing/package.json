{
  "dependencies": {
    "@genfeedai/enums": "workspace:*",
    "@genfeedai/interfaces": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "typescript": "6.0.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "name": "@genfeedai/pricing",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "directory": "pricing",
    "type": "git",
    "url": "git+https://github.com/genfeedai/packages.git"
  },
  "type": "module",
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit"
  },
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "version": "0.1.0"
}
