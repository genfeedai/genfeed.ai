{
  "dependencies": {
    "@genfeedai/constants": "workspace:*",
    "@genfeedai/enums": "workspace:*",
    "@genfeedai/helpers": "workspace:*",
    "ts-jsonapi": "2.1.3"
  },
  "description": "Genfeed.ai canonical JSON:API serializers",
  "devDependencies": {
    "typescript": "6.0.2"
  },
  "exports": {
    ".": {
      "bun": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./deserializer": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "name": "@genfeedai/serializers",
  "private": false,
  "scripts": {
    "build": "tsc --build --force && if [ -d dist/src ]; then mv dist/src/* dist/ 2>/dev/null && rm -rf dist/src; fi",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "deps:update": "bunx npm-check-updates -u --reject typescript && bun install",
    "dev": "tsc --watch",
    "test": "vitest run --config vitest.config.ts",
    "test:cov": "vitest run --coverage --config vitest.config.ts",
    "test:coverage": "vitest run --coverage --config vitest.config.ts",
    "test:watch": "vitest watch --config vitest.config.ts",
    "type-check": "tsc --noEmit"
  },
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "version": "2.2.2"
}
