{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "paths": {
      "@genfeedai/serializers/*": ["./src/*"],
      "@serializers/*": ["./src/*"]
    },
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "rootDir": "./src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ES2022"
  },
  "exclude": ["dist", "node_modules", "**/*.spec.ts", "**/*.test.ts"],
  "extends": "../../tsconfig.json",
  "include": ["src/**/*"]
}
