{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "paths": {
      "@genfeedai/serializers/*": ["./src/*"],
      "@serializers/*": ["./src/*"]
    },
    "rootDir": "./src",
    "sourceMap": true,
    "target": "ES2020"
  },
  "exclude": ["dist", "node_modules", "**/*.spec.ts", "**/*.test.ts"],
  "extends": "../../tsconfig.json",
  "include": ["src/**/*"]
}
