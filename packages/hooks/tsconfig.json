{
  "compilerOptions": {
    "paths": {
      "@genfeedai/contexts/*": ["../contexts/*"],
      "@genfeedai/models/*": ["../models/*"],
      "@genfeedai/props/*": ["../props/*"],
      "@genfeedai/providers/*": ["../providers/*"],
      "@genfeedai/services/*": ["../services/*"],
      "@genfeedai/utils/*": ["../utils/*"],
      "@hooks/*": ["./*"],
      "@providers/*": ["../providers/*"],
      "@props/*": ["../props/*"],
      "@ui-constants/*": ["../ui/constants/*"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"],
  "extends": "../tsconfig/base.json",
  "include": ["**/*.ts", "**/*.tsx"]
}
