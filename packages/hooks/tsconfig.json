  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@hooks/*": ["./*"],
      "@props/*": ["../props/*"],
      "@ui-constants/*": ["../ui/constants/*"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"],
  "extends": "../tsconfig/base.json",
  "include": ["**/*.ts", "**/*.tsx"]
}
