{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "..",
    "paths": {
      "@genfeedai/interfaces": ["../interfaces/src/index.ts"],
      "@genfeedai/interfaces/*": ["../interfaces/src/*"],
      "@genfeedai/workflow-engine/*": ["./src/*"],
      "@genfeedai/workflows/contracts": ["./src/workflows-contracts-shim.ts"],
      "@workflow-engine/*": ["./src/*"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  },
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"],
  "include": ["src/**/*"]
}
