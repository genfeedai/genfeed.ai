{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "incremental": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "paths": {
      "@api-types/*": ["../api-types/src/*"],
      "@genfeedai-types/*": ["../types/src/*"],
      "@genfeedai/agent": ["../agent/src/index.ts"],
      "@genfeedai/agent/*": ["../agent/src/*"],
      "@genfeedai/client": ["../client/src/index.ts"],
      "@genfeedai/client/*": ["../client/src/*"],
      "@genfeedai/constants": ["../constants/src/index.ts"],
      "@genfeedai/constants/*": ["../constants/src/*"],
      "@genfeedai/contexts/*": ["../contexts/*"],
      "@genfeedai/enums": ["../enums/src/index.ts"],
      "@genfeedai/enums/*": ["../enums/src/*"],
      "@genfeedai/helpers": ["../helpers/src/index.ts"],
      "@genfeedai/helpers/*": ["../helpers/src/*"],
      "@genfeedai/hooks/*": ["../hooks/*"],
      "@genfeedai/interfaces": ["../interfaces/src/index.ts"],
      "@genfeedai/interfaces/*": ["../interfaces/src/*"],
      "@genfeedai/models/*": ["../models/*"],
      "@genfeedai/props/*": ["../props/*"],
      "@genfeedai/providers/*": ["../providers/*"],
      "@genfeedai/serializers": ["../serializers/src/index.ts"],
      "@genfeedai/serializers/*": ["../serializers/src/*"],
      "@genfeedai/services/*": ["../services/*"],
      "@genfeedai/types": ["../types/src/index.ts"],
      "@genfeedai/types/*": ["../types/src/*"],
      "@genfeedai/ui/*": ["../ui/src/*", "../ui/src/components/*"],
      "@genfeedai/utils/*": ["../utils/*"],
      "@genfeedai/workflow-engine/*": ["../workflow-engine/src/*"],
      "@genfeedai/workflow-saas/*": ["../workflow-saas/src/*"],
      "@components/*": ["../ui/src/components/*"],
      "@configs/*": ["../next-config/*"],
      "@contexts/*": ["../contexts/*"],
      "@helpers/*": ["../helpers/src/*"],
      "@hooks/*": ["../hooks/*"],
      "@models/*": ["../models/*"],
      "@pages/*": ["../pages/*"],
      "@props/*": ["../props/*"],
      "@providers/*": ["../providers/*"],
      "@schemas/*": ["../schemas/*"],
      "@serializers/*": ["../serializers/src/*"],
      "@services/*": ["../services/*"],
      "@styles/*": ["../styles/*"],
      "@ui-constants/*": ["../ui/src/components/constants/*"],
      "@ui/*": ["../ui/src/*", "../ui/src/components/*"],
      "@utils/*": ["../utils/*"],
      "@workflow-engine/*": ["../workflow-engine/src/*"],
      "@workflow-saas/*": ["../workflow-saas/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ],
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "target": "es2022",
    "types": []
  },
  "exclude": ["node_modules"]
}
