{
  "dependencies": {
    "@genfeedai/enums": "workspace:*"
  },
  "description": "Shared types and utilities for platform integrations",
  "devDependencies": {
    "@types/node": "26.0.1",
    "typescript": "6.0.2"
  },
  "exports": {
    "./ads": {
      "types": "./dist/ads/index.d.ts",
      "import": "./dist/ads/index.js",
      "default": "./dist/ads/index.js"
    },
    "./catalog": {
      "types": "./dist/catalog/index.d.ts",
      "import": "./dist/catalog/index.js",
      "default": "./dist/catalog/index.js"
    },
    "./connections": {
      "types": "./dist/connections/index.d.ts",
      "import": "./dist/connections/index.js",
      "default": "./dist/connections/index.js"
    },
    "./http": {
      "types": "./dist/http/index.d.ts",
      "import": "./dist/http/index.js",
      "default": "./dist/http/index.js"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "dist/index.js",
  "name": "@genfeedai/integrations",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "biome lint --write src",
    "test": "vitest run --config vitest.config.ts",
    "test:cov": "vitest run --coverage --config vitest.config.ts",
    "test:watch": "vitest watch --config vitest.config.ts"
  },
  "sideEffects": false,
  "types": "dist/index.d.ts",
  "version": "1.0.0"
}
