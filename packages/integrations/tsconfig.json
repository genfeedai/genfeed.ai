{
  "compilerOptions": {
    "declaration": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "paths": {
      "@genfeedai/enums": ["../enums/src/index.ts"],
      "@genfeedai/enums/*": ["../enums/src/*"],
      "@genfeedai/helpers": ["../helpers/src/index.ts"],
      "@genfeedai/helpers/*": ["../helpers/src/*"],
      "@genfeedai/integrations/*": ["./src/*"],
      "@genfeedai/interfaces": ["../interfaces/src/index.ts"],
      "@genfeedai/interfaces/*": ["../interfaces/src/*"],
      "@integrations/*": ["./src/*"]
    },
    "rootDir": "src",
    "target": "es2022"
  },
  "exclude": ["dist", "node_modules", "**/*.spec.ts", "**/*.test.ts"],
  "extends": "../../tsconfig.json",
  "include": ["src/**/*"],
  "references": [
    {
      "path": "../enums"
    },
    {
      "path": "../helpers"
    },
    {
      "path": "../interfaces"
    }
  ]
}
