{
  "dependencies": {
    "@genfeedai/props": "workspace:*",
    "@genfeedai/services": "workspace:*"
  },
  "description": "Shared framework-agnostic utility functions for Genfeed applications",
  "devDependencies": {
    "vitest": "4.1.4"
  },
  "exports": {
    "./*": "./*"
  },
  "name": "@genfeedai/utils",
  "private": true,
  "scripts": {
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest watch --config vitest.config.ts",
    "type-check": "tsc --noEmit"
  },
  "sideEffects": false,
  "version": "0.1.0"
}
