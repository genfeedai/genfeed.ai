{
  "compilerOptions": {
    "paths": {
      "@agent-tests/*": ["./tests/*"],
      "@genfeedai/agent": ["./src/index.ts"],
      "@genfeedai/agent/*": ["./src/*"],
      "@genfeedai/contexts/*": ["../contexts/*"],
      "@helpers/*": ["../helpers/src/*"],
      "@hooks/*": ["../hooks/*"],
      "@genfeedai/models/*": ["../models/*"],
      "@genfeedai/pages/*": ["../pages/*"],
      "@genfeedai/props/*": ["../props/*"],
      "@genfeedai/services/*": ["../services/*"],
      "@genfeedai/utils/*": ["../utils/*"],
      "@ui-constants/*": ["../ui/constants/*"],
      "@ui/*": ["../ui/src/*", "../ui/src/components/*"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"],
  "extends": "../tsconfig/base.json",
  "include": ["**/*.ts", "**/*.tsx"]
}
