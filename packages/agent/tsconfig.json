{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@agent-tests/*": ["./tests/*"],
      "@genfeedai/agent": ["./src/index.ts"],
      "@genfeedai/agent/*": ["./src/*"],
      "@contexts/*": ["../contexts/*"],
      "@helpers/*": ["../helpers/src/*"],
      "@hooks/*": ["../hooks/*"],
      "@models/*": ["../models/*"],
      "@pages/*": ["../pages/*"],
      "@props/*": ["../props/*"],
      "@services/*": ["../services/*"],
      "@ui-constants/*": ["../ui/constants/*"],
      "@ui/*": ["../ui/*"]
    }
  },
  "exclude": ["node_modules", "dist"],
  "extends": "../tsconfig/base.json",
  "include": ["**/*.ts", "**/*.tsx"]
}
