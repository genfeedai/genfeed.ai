{
  "author": "Genfeed.ai",
  "bin": {
    "genfeed": "dist/index.js",
    "gf": "dist/index.js"
  },
  "dependencies": {
    "@genfeedai/deserializer": "workspace:*",
    "@genfeedai/tools": "workspace:*",
    "@inquirer/prompts": "8.3.2",
    "chalk": "5.6.2",
    "commander": "14.0.3",
    "ofetch": "1.5.1",
    "ora": "9.3.0",
    "socket.io-client": "4.8.3",
    "zod": "4.3.6"
  },
  "description": "Unified CLI for Genfeed.ai - Generate, train, publish, and manage AI content from your terminal",
  "devDependencies": {
    "@biomejs/biome": "2.4.10",
    "@types/bun": "1.3.11",
    "@types/node": "25.5.2",
    "@vitest/coverage-v8": "4.1.2",
    "typescript": "6.0.2",
    "vitest": "4.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "homepage": "https://genfeed.ai",
  "keywords": [
    "genfeed",
    "ai",
    "image-generation",
    "video-generation",
    "training",
    "darkroom",
    "cli"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "name": "@genfeedai/cli",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "directory": "packages/cli",
    "type": "git",
    "url": "git+https://github.com/genfeedai/genfeed.ai.git"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node",
    "build:standalone": "bun build src/index.ts --compile --outfile gf",
    "deps:update": "bunx npm-check-updates -u && bun install",
    "dev": "bun run src/index.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepack": "bun run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "type": "module",
  "version": "0.4.0"
}
