{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "outDir": "dist",
    "paths": {
      "@/*": ["./src/*"],
      "@genfeedai/constants": ["../constants/src/index.ts"],
      "@genfeedai/constants/*": ["../constants/src/*"],
      "@genfeedai/enums": ["../enums/src/index.ts"],
      "@genfeedai/enums/*": ["../enums/src/*"],
      "@genfeedai/errors": ["../errors/src/index.ts"],
      "@genfeedai/helpers": ["../helpers/src/index.ts"],
      "@genfeedai/helpers/*": ["../helpers/src/*"],
      "@genfeedai/interfaces/*": ["../interfaces/src/*"],
      "@genfeedai/serializers": ["../helpers/src/deserializer/index.ts"],
      "@genfeedai/tools": ["../tools/src/index.ts"]
    },
    "resolveJsonModule": true,
    "rootDir": "..",
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "types": ["bun", "node"]
  },
  "exclude": ["node_modules", "dist", "tests"],
  "include": ["src/**/*"]
}
