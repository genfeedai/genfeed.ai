  isDeleted       Boolean      @default(false)
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  tags            Tag[]        @relation("folder_tags")
  ingredients     Ingredient[]
  bookmarks       Bookmark[]

