model SubscriptionAttribution {
  id              String       @id @default(cuid())
  mongoId                 String?         @unique
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  userId          String
  user            User         @relation(fields: [userId], references: [id])
  sourceContentId String?
  sourceContent   Post?        @relation("attribution_content", fields: [sourceContentId], references: [id])
  sourceLinkId    String?
  sourceLink      TrackedLink? @relation("attribution_link", fields: [sourceLinkId], references: [id])
  channel         String?
  referrer        String?
  metadata        Json?
