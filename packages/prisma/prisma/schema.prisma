  mongoId        String?  @unique
  organizationId String
  userId         String
  externalId     String?
  status         String?
  data           Json     @default("{}")
  isDeleted      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, externalId])
  @@index([organizationId, isDeleted, status])
  @@map("fanvue_subscribers")
}

model LivestreamBotSession {
  id        String   @id @default(cuid())
  mongoId   String?  @unique
  data      Json     @default("{}")
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("livestream_bot_sessions")
}

model Run {
  id             String    @id @default(cuid())
  mongoId        String?   @unique
  organizationId String
  brandId        String?
  userId         String?
  actionType     String?
  authType       String?
  surface        String?
  trigger        String?
  status         String?
  idempotencyKey String?
  traceId        String?
  correlationId  String?
  progress       Int?
  durationMs     Int?
  error          String?
  startedAt      DateTime?
  completedAt    DateTime?
  input          Json?
  output         Json?
  metadata       Json?
  events         Json?
  data           Json      @default("{}")
  isDeleted      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@map("runs")
}

model Analytic {
  id        String   @id @default(cuid())
  mongoId   String?  @unique
  data      Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("analytics")
}

model DesktopThread {
  id             String           @id
  userId         String?          @map("user_id")
  organizationId String?          @map("organization_id")
  localUserId    String?          @map("local_user_id")
  title          String           @default("New conversation")
  status         String           @default("idle")
  workspaceId    String?
  createdAt      DateTime
  updatedAt      DateTime
  messages       DesktopMessage[]

  @@index([userId, updatedAt(sort: Desc)])
  @@index([organizationId, updatedAt(sort: Desc)])
  @@index([organizationId, userId, updatedAt(sort: Desc)])
  @@map("desktop_threads")
}

model DesktopMessage {
  id               String        @id
  threadId         String
  role             String
  content          String
  createdAt        DateTime
  draftId          String?
  generatedContent Json?
  thread           DesktopThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([threadId, createdAt, id])
  @@map("desktop_messages")
}
