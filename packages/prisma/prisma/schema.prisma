// ─────────────────────────────────────────────────────────────
// Genfeed.ai — Prisma Schema (PostgreSQL)
// Migrated from the legacy MongoDB stack — ownership integrity is #1 priority
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma/client"
}

datasource db {
  provider = "postgresql"
}

