  config            Json         @default("{}")
  status            String?
  sourceContentId   String?
  sourceContentType String?
  targetFormats     Json?
  results           Json?
  settings          Json?
  isDeleted         Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  @@map("repurposing_jobs")
}

