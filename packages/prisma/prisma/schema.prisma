  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  tags             Tag[]              @relation("metadata_tags")
  ingredients      Ingredient[]

  @@index([externalId])
  @@index([externalProvider])
  @@map("metadata")
}

model Prompt {
  id               String          @id @default(cuid())
  mongoId                 String?         @unique
