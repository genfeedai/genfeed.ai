{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "paths": {
      "@genfeedai/config": ["./src/index.ts"],
      "@genfeedai/config/*": ["./src/*"],
      "@config/*": ["./src/*"]
    },
    "rootDir": "./src",
    "sourceMap": true
  },
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"],
  "extends": "../../tsconfig.json",
  "include": ["src/**/*"]
}
