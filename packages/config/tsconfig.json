{
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "paths": {
      "@genfeedai/config": ["./src/index.ts"],
      "@genfeedai/config/*": ["./src/*"],
      "@genfeedai/pricing": ["../pricing/src/index.ts"],
      "@genfeedai/pricing/*": ["../pricing/src/*"],
      "@config/*": ["./src/*"]
    },
    "rootDir": "./src",
    "sourceMap": true,
    "target": "es2022"
  },
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"],
  "extends": "../../tsconfig.json",
  "include": ["src/**/*"],
  "references": [
    {
      "path": "../pricing"
    }
  ]
}
