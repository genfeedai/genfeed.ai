{
  "dependencies": {
    "dotenv": "17.4.2",
    "joi": "18.2.1"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "typescript": "6.0.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js",
      "import": "./dist/*.js"
    },
    "./interfaces": {
      "types": "./dist/interfaces/index.d.ts",
      "default": "./dist/interfaces/index.js",
      "import": "./dist/interfaces/index.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "default": "./dist/schemas/index.js",
      "import": "./dist/schemas/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "main": "./dist/index.js",
  "name": "@genfeedai/config",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc --build && if [ -d dist/src ]; then mv dist/src/* dist/ 2>/dev/null && rm -rf dist/src; fi",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsc --watch",
    "test": "vitest run --config vitest.config.ts",
    "test:cov": "vitest run --coverage --config vitest.config.ts",
    "test:watch": "vitest watch --config vitest.config.ts",
    "type-check": "tsc --noEmit"
  },
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "*": [
        "dist/index.d.ts"
      ],
      "interfaces": [
        "dist/interfaces/index.d.ts"
      ],
      "schemas": [
        "dist/schemas/index.d.ts"
      ]
    }
  },
  "version": "1.0.0"
}
