{
  "dependencies": {
    "@genfeedai/pricing": "workspace:*",
    "@genfeedai/types": "workspace:*"
  },
  "description": "Core utilities for Genfeed workflow engine",
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.10",
    "tsup": "8.5.1",
    "typescript": "6.0.2",
    "vitest": "4.1.10"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./topological-sort": {
      "types": "./dist/topological-sort.d.ts",
      "default": "./dist/topological-sort.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "default": "./dist/validation.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "AGPL-3.0",
  "main": "./dist/index.js",
  "name": "@genfeedai/core",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "directory": "core",
    "type": "git",
    "url": "git+https://github.com/genfeedai/packages.git"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "bun run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "version": "0.2.1"
}
