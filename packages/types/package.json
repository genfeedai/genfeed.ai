{
  "description": "Type definitions for Genfeed workflow engine",
  "devDependencies": {
    "@xyflow/react": "12.11.2",
    "tsup": "8.5.1",
    "typescript": "6.0.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./comfyui": {
      "types": "./dist/comfyui.d.ts",
      "default": "./dist/comfyui.js"
    },
    "./nodes": {
      "types": "./dist/nodes.d.ts",
      "default": "./dist/nodes.js"
    },
    "./replicate": {
      "types": "./dist/replicate.d.ts",
      "default": "./dist/replicate.js"
    },
    "./replicate/schemas.json": "./src/replicate/schemas.json",
    "./workflow": {
      "types": "./dist/workflow.d.ts",
      "default": "./dist/workflow.js"
    }
  },
  "files": [
    "dist",
    "src/replicate/schemas.json"
  ],
  "license": "AGPL-3.0",
  "main": "./dist/index.js",
  "name": "@genfeedai/types",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "directory": "packages/types",
    "type": "git",
    "url": "git+https://github.com/genfeedai/genfeed.ai.git"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "bun run build"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "version": "0.3.2"
}
