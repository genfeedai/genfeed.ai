generator client {
  provider     = "prisma-client"
  output       = "../generated/desktop-prisma/client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model DesktopKv {
  key   String @id
  value String

  @@map("desktop_kv")
}

model DesktopWorkspace {
  id               String  @id
  name             String
  path             String  @unique
  linkedProjectId  String? @map("linked_project_id")
  fileIndex        String  @default("[]") @map("file_index")
  indexingState    String  @default("idle") @map("indexing_state")
  localDraftCount  Int     @default(0) @map("local_draft_count")
  pendingSyncCount Int     @default(0) @map("pending_sync_count")
  createdAt        String  @map("created_at")
  updatedAt        String  @map("updated_at")
  lastOpenedAt     String  @map("last_opened_at")

  @@index([lastOpenedAt(sort: Desc)])
  @@map("desktop_workspace")
}

model DesktopSyncJob {
  id         String  @id
  workspaceId String? @map("workspace_id")
  type       String
  payload    String
  status     String
  error      String?
  retryCount Int     @default(0) @map("retry_count")
  createdAt  String  @map("created_at")
  updatedAt  String  @map("updated_at")

  @@index([workspaceId, updatedAt(sort: Desc)])
  @@index([status, updatedAt(sort: Desc)])
  @@map("desktop_sync_job")
}

model DesktopRecentItem {
  id       String @id
  kind     String
  label    String
  value    String
  openedAt String @map("opened_at")

  @@index([openedAt(sort: Desc)])
  @@map("desktop_recent_item")
}

model DesktopOrganization {
  id        String @id
  name      String
  slug      String @unique
  createdAt String @map("created_at")
  updatedAt String @map("updated_at")

  users        DesktopUser[]
  projects     DesktopProject[]
  contentItems DesktopContentItem[]
  trends       DesktopTrend[]
  ingredients  DesktopIngredient[]
  agents       DesktopAgent[]
  workflows    DesktopWorkflow[]

  @@map("desktop_organization")
}

model DesktopUser {
  id             String  @id
  organizationId String  @map("organization_id")
  clerkId        String? @unique @map("clerk_id")
  email          String?
  name           String
  createdAt      String  @map("created_at")
  updatedAt      String  @map("updated_at")

  organization DesktopOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("desktop_user")
}

model DesktopProject {
  id             String @id
  organizationId String @map("organization_id")
  name           String
  status         String
  createdAt      String @map("created_at")
  updatedAt      String @map("updated_at")

  organization DesktopOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contentItems  DesktopContentItem[]

  @@index([organizationId, updatedAt(sort: Desc)])
  @@map("desktop_project")
}

model DesktopContentItem {
  id               String  @id
  organizationId   String  @map("organization_id")
  projectId        String? @map("project_id")
  platform         String
  type             String
  prompt           String
  content          String
  status           String
  publishIntent    String? @map("publish_intent")
  sourceDraftId    String? @unique @map("source_draft_id")
  sourceTrendId    String? @map("source_trend_id")
  sourceTrendTopic String? @map("source_trend_topic")
  publishedAt      String? @map("published_at")
  views            Int     @default(0)
  engagements      Int     @default(0)
  createdAt        String  @map("created_at")
  updatedAt        String  @map("updated_at")

  organization DesktopOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      DesktopProject?     @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@index([organizationId, updatedAt(sort: Desc)])
  @@index([status, publishedAt(sort: Desc)])
  @@index([platform, updatedAt(sort: Desc)])
  @@map("desktop_content_item")
}

model DesktopTrend {
  id              String  @id
  organizationId  String  @map("organization_id")
  platform        String
  topic           String
  summary         String?
  viralityScore   Int     @map("virality_score")
  engagementScore Int     @map("engagement_score")
  createdAt       String  @map("created_at")

  organization DesktopOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, platform, topic])
  @@map("desktop_trend")
}

model DesktopIngredient {
  id                  String  @id
  organizationId      String  @map("organization_id")
  title               String
  content             String
  platform            String?
  totalVotes          Int     @default(0) @map("total_votes")
  sourceContentItemId String? @map("source_content_item_id")
  createdAt           String  @map("created_at")
  updatedAt           String  @map("updated_at")

  organization DesktopOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, updatedAt(sort: Desc)])
  @@index([platform, totalVotes(sort: Desc)])
  @@map("desktop_ingredient")
}

model DesktopAgent {
  id             String @id
  organizationId String @map("organization_id")
  name           String
  avatar         String?
  platformsJson  String @default("[]") @map("platforms_json")
  status         String
  isActive       Boolean @default(true) @map("is_active")
  lastRunAt      String? @map("last_run_at")
  createdAt      String @map("created_at")
  updatedAt      String @map("updated_at")

  organization DesktopOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  runs         DesktopAgentRun[]

  @@index([organizationId, updatedAt(sort: Desc)])
  @@map("desktop_agent")
}

model DesktopAgentRun {
  id          String  @id
  agentId     String  @map("agent_id")
  status      String
  startedAt   String  @map("started_at")
  completedAt String? @map("completed_at")

  agent DesktopAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, startedAt(sort: Desc)])
  @@map("desktop_agent_run")
}

model DesktopWorkflow {
  id             String @id
  organizationId String @map("organization_id")
  name           String
  description    String?
  lifecycle      String
  nodeCount      Int    @map("node_count")
  supportsBatch  Boolean @default(false) @map("supports_batch")
  lastExecutedAt String? @map("last_executed_at")
  createdAt      String @map("created_at")
  updatedAt      String @map("updated_at")

  organization DesktopOrganization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  runs         DesktopWorkflowRun[]

  @@index([organizationId, updatedAt(sort: Desc)])
  @@map("desktop_workflow")
}

model DesktopWorkflowRun {
  id          String  @id
  workflowId  String  @map("workflow_id")
  mode        String
  status      String
  startedAt   String  @map("started_at")
  completedAt String? @map("completed_at")

  workflow DesktopWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId, startedAt(sort: Desc)])
  @@map("desktop_workflow_run")
}
