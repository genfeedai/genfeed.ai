{
  "dependencies": {
    "@dagrejs/dagre": "3.0.0",
    "@genfeedai/core": "workspace:*",
    "@genfeedai/types": "workspace:*",
    "@genfeedai/ui": "workspace:*",
    "@radix-ui/react-checkbox": "1.3.6",
    "@radix-ui/react-label": "2.1.11",
    "@radix-ui/react-select": "2.3.2",
    "@radix-ui/react-slider": "1.4.2",
    "@radix-ui/react-slot": "1.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.23.0",
    "nanoid": "5.1.16",
    "tailwind-merge": "3.6.0"
  },
  "description": "Shared UI components for Genfeed workflow editor",
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@xyflow/react": "12.11.1",
    "jsdom": "29.1.1",
    "react": "19.2.7",
    "react-compare-slider": "4.0.0",
    "react-dom": "19.2.7",
    "tsup": "8.5.1",
    "typescript": "6.0.2",
    "vitest": "4.1.10",
    "zundo": "2.3.0",
    "zustand": "5.0.14"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./canvas": {
      "types": "./dist/canvas.d.ts",
      "import": "./dist/canvas.mjs",
      "default": "./dist/canvas.mjs"
    },
    "./hooks": {
      "types": "./dist/hooks.d.ts",
      "import": "./dist/hooks.mjs",
      "default": "./dist/hooks.mjs"
    },
    "./lib": {
      "types": "./dist/lib.d.ts",
      "import": "./dist/lib.mjs",
      "default": "./dist/lib.mjs"
    },
    "./nodes": {
      "types": "./dist/nodes.d.ts",
      "import": "./dist/nodes.mjs",
      "default": "./dist/nodes.mjs"
    },
    "./panels": {
      "types": "./dist/panels.d.ts",
      "import": "./dist/panels.mjs",
      "default": "./dist/panels.mjs"
    },
    "./provider": {
      "types": "./dist/provider.d.ts",
      "import": "./dist/provider.mjs",
      "default": "./dist/provider.mjs"
    },
    "./stores": {
      "types": "./dist/stores.d.ts",
      "import": "./dist/stores.mjs",
      "default": "./dist/stores.mjs"
    },
    "./styles": "./src/styles/workflow-ui.css",
    "./toolbar": {
      "types": "./dist/toolbar.d.ts",
      "import": "./dist/toolbar.mjs",
      "default": "./dist/toolbar.mjs"
    },
    "./ui": {
      "types": "./dist/ui.d.ts",
      "import": "./dist/ui.mjs",
      "default": "./dist/ui.mjs"
    }
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "license": "AGPL-3.0",
  "module": "./dist/index.mjs",
  "name": "@genfeedai/workflow-ui",
  "peerDependencies": {
    "@xyflow/react": ">=12.0.0",
    "next": ">=14.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "zundo": ">=2.0.0",
    "zustand": ">=5.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "directory": "workflow-ui",
    "type": "git",
    "url": "git+https://github.com/genfeedai/packages.git"
  },
  "scripts": {
    "build": "tsup && bun run scripts/prepend-use-client.ts",
    "dev": "tsup --watch",
    "prepublishOnly": "bun run build",
    "release:npm": "../../scripts/publish-package.sh . --no-bump",
    "release:npm:dry-run": "../../scripts/publish-package.sh . --no-bump --dry-run",
    "test": "vitest run"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "version": "0.2.8"
}
