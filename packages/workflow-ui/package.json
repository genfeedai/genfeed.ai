{
  "dependencies": {
    "@dagrejs/dagre": "3.0.0",
    "@genfeedai/core": "workspace:*",
    "@genfeedai/types": "workspace:*",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-slider": "1.3.6",
    "@radix-ui/react-slot": "1.2.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.7.0",
    "nanoid": "5.1.7",
    "tailwind-merge": "3.5.0"
  },
  "description": "Shared UI components for Genfeed workflow editor",
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@xyflow/react": "12.10.2",
    "jsdom": "29.0.1",
    "react": "19.2.4",
    "react-compare-slider": "4.0.0",
    "react-dom": "19.2.4",
    "tsup": "8.5.1",
    "typescript": "5.9.3",
    "vitest": "4.1.2",
    "zundo": "2.3.0",
    "zustand": "5.0.12"
  },
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.ts"
    },
    "./canvas": {
      "import": "./dist/canvas.mjs",
      "types": "./dist/canvas.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks.mjs",
      "types": "./dist/hooks.d.ts"
    },
    "./lib": {
      "import": "./dist/lib.mjs",
      "types": "./dist/lib.d.ts"
    },
    "./nodes": {
      "import": "./dist/nodes.mjs",
      "types": "./dist/nodes.d.ts"
    },
    "./panels": {
      "import": "./dist/panels.mjs",
      "types": "./dist/panels.d.ts"
    },
    "./provider": {
      "import": "./dist/provider.mjs",
      "types": "./dist/provider.d.ts"
    },
    "./stores": {
      "import": "./dist/stores.mjs",
      "types": "./dist/stores.d.ts"
    },
    "./styles": "./src/styles/workflow-ui.css",
    "./toolbar": {
      "import": "./dist/toolbar.mjs",
      "types": "./dist/toolbar.d.ts"
    },
    "./ui": {
      "import": "./dist/ui.mjs",
      "types": "./dist/ui.d.ts"
    }
  },
  "files": [
    "dist",
    "src/styles"
  ],
  "license": "AGPL-3.0",
  "module": "./dist/index.mjs",
  "name": "@genfeedai/workflow-ui",
  "peerDependencies": {
    "@xyflow/react": ">=12.0.0",
    "next": ">=14.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "zundo": ">=2.0.0",
    "zustand": ">=5.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "directory": "workflow-ui",
    "type": "git",
    "url": "git+https://github.com/genfeedai/packages.git"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "bun run build",
    "publish": "PACKAGE_FILTER=workflow-ui PUBLISH_PROVENANCE=0 node ../scripts/publish-public-packages.mjs",
    "publish:dry-run": "PACKAGE_FILTER=workflow-ui PUBLISH_DRY_RUN=1 PUBLISH_PROVENANCE=0 node ../scripts/publish-public-packages.mjs",
    "test": "vitest run"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "version": "0.2.8"
}
