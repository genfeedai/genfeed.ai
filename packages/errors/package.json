{
  "dependencies": {
    "chalk": "5.6.2"
  },
  "description": "Shared error classes and formatting for Genfeed CLI tools",
  "devDependencies": {
    "@types/node": "25.6.0",
    "tsup": "8.5.1",
    "typescript": "6.0.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "name": "@genfeedai/errors",
