{
  "dependencies": {
    "@genfeedai/constants": "workspace:*",
    "@genfeedai/enums": "workspace:*",
    "@genfeedai/interfaces": "workspace:*",
    "zod": "4.4.3"
  },
  "description": "Genfeed.ai shared client models and schemas",
  "devDependencies": {
    "typescript": "6.0.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "default": "./dist/models/index.js"
    },
    "./models/social": {
      "types": "./dist/models/social/index.d.ts",
      "default": "./dist/models/social/index.js"
    },
    "./models/*": {
      "types": "./dist/models/*.d.ts",
      "default": "./dist/models/*.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "default": "./dist/schemas/index.js"
    },
    "./schemas/*": {
      "types": "./dist/schemas/*.d.ts",
      "default": "./dist/schemas/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "name": "@genfeedai/client",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "directory": "client",
    "type": "git",
    "url": "git+https://github.com/genfeedai/packages.git"
  },
  "scripts": {
    "build": "tsc --build && test -f dist/index.js",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "deps:update": "bunx npm-check-updates -u && bun install",
    "test": "vitest run --config vitest.config.ts",
    "test:cov": "vitest run --config vitest.config.ts --coverage"
  },
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "models": [
        "dist/models/index.d.ts"
      ],
      "models/social": [
        "dist/models/social/index.d.ts"
      ],
      "models/*": [
        "dist/models/*"
      ],
      "schemas": [
        "dist/schemas/index.d.ts"
      ],
      "schemas/*": [
        "dist/schemas/*"
      ]
    }
  },
  "version": "2.3.1"
}
