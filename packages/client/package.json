{
  "dependencies": {
    "@genfeedai/constants": "workspace:*",
    "@genfeedai/enums": "workspace:*",
    "@genfeedai/helpers": "workspace:*",
    "@genfeedai/interfaces": "workspace:*",
    "ts-jsonapi": "2.1.3",
    "zod": "4.3.6"
  },
  "description": "Genfeed.ai shared client models and schemas",
  "devDependencies": {
    "typescript": "6.0.2"
  },
  "exports": {
    ".": {
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./models": {
      "default": "./dist/models/index.js",
      "types": "./dist/models/index.d.ts"
    },
    "./models/*": {
      "default": "./dist/models/*.js",
      "types": "./dist/models/*.d.ts"
    },
    "./schemas": {
      "default": "./dist/schemas/index.js",
      "types": "./dist/schemas/index.d.ts"
    },
    "./schemas/*": {
      "default": "./dist/schemas/*.js",
      "types": "./dist/schemas/*.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "main": "dist/index.js",
  "name": "@genfeedai/client",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "directory": "client",
    "type": "git",
    "url": "git+https://github.com/genfeedai/packages.git"
  },
  "scripts": {
    "build": "tsc --build --force && if [ -d dist/src ]; then mv dist/src/* dist/ 2>/dev/null && rm -rf dist/src; fi",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "deps:update": "bunx npm-check-updates -u && bun install",
    "test": "vitest run --config vitest.config.ts",
    "test:cov": "vitest run --config vitest.config.ts --coverage"
  },
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "models": [
        "dist/models/index.d.ts"
      ],
      "models/*": [
        "dist/models/*"
      ],
      "schemas": [
        "dist/schemas/index.d.ts"
      ],
      "schemas/*": [
        "dist/schemas/*"
      ]
    }
  },
  "version": "2.3.1"
}
