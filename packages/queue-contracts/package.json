{
  "dependencies": {
    "@genfeedai/enums": "workspace:*"
  },
  "devDependencies": {
    "typescript": "6.0.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "name": "@genfeedai/queue-contracts",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "directory": "packages/queue-contracts",
    "type": "git",
    "url": "git+https://github.com/genfeedai/genfeed.ai.git"
  },
  "scripts": {
    "build": "tsc --build && node ../../scripts/fix-esm-relative-imports.mjs --project tsconfig.json dist",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsc --watch",
    "test": "vitest run --config vitest.config.ts",
    "type-check": "tsc --noEmit"
  },
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "version": "0.1.0"
}
