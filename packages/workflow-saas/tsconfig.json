{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "ignoreDeprecations": "6.0",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "..",
    "paths": {
      "@genfeedai/enums": ["../enums/src/index.ts"],
      "@genfeedai/enums/*": ["../enums/src/*"],
      "@genfeedai/interfaces": ["../interfaces/src/index.ts"],
      "@genfeedai/interfaces/*": ["../interfaces/src/*"],
      "@genfeedai/types": ["../types/src/index.ts"],
      "@genfeedai/types/*": ["../types/src/*"],
      "@genfeedai/workflow-saas/*": ["./src/*"],
      "@genfeedai/workflows": ["../workflows/src/index.ts"],
      "@genfeedai/workflows/*": ["../workflows/src/*"],
      "@workflow-saas/*": ["./src/*"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022"
  },
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"],
  "include": ["src/**/*"]
}
