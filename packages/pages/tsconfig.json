{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@genfeedai/agent": ["../agent/src/index.ts"],
      "@genfeedai/agent/*": ["../agent/src/*"],
      "@contexts/*": ["../contexts/*"],
      "@helpers/*": ["../helpers/src/*"],
      "@hooks/*": ["../hooks/*"],
      "@models/*": ["../models/*"],
      "@pages/*": ["./*"],
      "@props/*": ["../props/*"],
      "@providers/*": ["../providers/*"],
      "@serializers/*": ["../serializers/src/*"],
      "@services/*": ["../services/*"],
      "@styles/*": ["../styles/*"],
      "@ui-constants/*": ["../ui/constants/*"],
      "@ui/*": ["../ui/*"],
      "@utils/*": ["../utils/*"]
    }
  },
  "exclude": ["node_modules", "dist"],
  "extends": "../tsconfig/base.json",
  "include": ["**/*.ts", "**/*.tsx"]
}
