{
  "compilerOptions": {
    "paths": {
      "@genfeedai/client": ["../client/src/index.ts"],
      "@genfeedai/client/*": ["../client/src/*"],
      "@genfeedai/constants": ["../constants/src/index.ts"],
      "@genfeedai/constants/*": ["../constants/src/*"],
      "@genfeedai/contexts/*": ["../contexts/*"],
      "@genfeedai/enums": ["../enums/src/index.ts"],
      "@genfeedai/enums/*": ["../enums/src/*"],
      "@genfeedai/helpers": ["../helpers/src/index.ts"],
      "@genfeedai/helpers/*": ["../helpers/src/*"],
      "@genfeedai/hooks/*": ["../hooks/*"],
      "@genfeedai/interfaces": ["../interfaces/src/index.ts"],
      "@genfeedai/interfaces/*": ["../interfaces/src/*"],
      "@genfeedai/models/*": ["../models/*"],
      "@genfeedai/props/*": ["../props/*"],
      "@genfeedai/providers/*": ["./*"],
      "@genfeedai/serializers": ["../serializers/src/index.ts"],
      "@genfeedai/serializers/*": ["../serializers/src/*"],
      "@genfeedai/services/*": ["../services/*"],
      "@genfeedai/types": ["../types/src/index.ts"],
      "@genfeedai/types/*": ["../types/src/*"],
      "@genfeedai/ui": ["../ui/src"],
      "@genfeedai/ui/*": ["../ui/src/*"],
      "@genfeedai/utils/*": ["../utils/*"],
      "@providers/*": ["./*"],
      "@ui-constants/*": ["../ui/src/components/constants/*"],
      "@api-types/*": ["../api-types/src/*"],
      "@contexts/*": ["../contexts/*"],
      "@helpers/*": ["../helpers/src/*"],
      "@hooks/*": ["../hooks/*"],
      "@models/*": ["../models/*"],
      "@pages/*": ["../pages/*"],
      "@props/*": ["../props/*"],
      "@schemas/*": ["../schemas/*"],
      "@serializers/*": ["../serializers/src/*"],
      "@services/*": ["../services/*"],
      "@styles/*": ["../styles/*"],
      "@ui/*": ["../ui/src/*", "../ui/src/components/*"],
      "@utils/*": ["../utils/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.stories.ts",
    "**/*.stories.tsx"
  ],
  "extends": "../tsconfig/base.json",
  "include": ["**/*.ts", "**/*.tsx"]
}
