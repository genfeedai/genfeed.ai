{
  "dependencies": {
    "@genfeedai/contexts": "workspace:*",
    "@genfeedai/helpers": "workspace:*",
    "@genfeedai/models": "workspace:*",
    "@genfeedai/props": "workspace:*",
    "@genfeedai/services": "workspace:*"
  },
  "description": "Shared React providers for Genfeed applications",
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@vitejs/plugin-react": "5.1.1",
    "jsdom": "29.0.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "vitest": "4.1.4"
  },
  "exports": {
    "./*": "./*"
  },
  "name": "@genfeedai/providers",
  "private": true,
  "scripts": {
    "test": "vitest run --config vitest.config.ts",
    "test:watch": "vitest watch --config vitest.config.ts",
    "type-check": "tsc --noEmit"
  },
  "sideEffects": false,
  "version": "0.1.0"
}
