{
  "dependencies": {
    "@genfeedai/constants": "workspace:*",
    "@genfeedai/enums": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "25.9.1",
    "@types/react": "19.2.16",
    "@types/react-dom": "19.2.3",
    "next": "16.2.7",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.77.0",
    "react-icons": "5.6.0",
    "typescript": "6.0.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "name": "@genfeedai/interfaces",
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "directory": "interfaces",
    "type": "git",
    "url": "git+https://github.com/genfeedai/packages.git"
  },
  "scripts": {
    "build": "tsc --build && if [ -d dist/src ]; then mv dist/src/* dist/ 2>/dev/null && rm -rf dist/src; fi",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "deps:update": "bunx npm-check-updates -u && bun install",
    "dev": "tsc --watch",
    "type-check": "tsc --noEmit"
  },
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "version": "2.3.20"
}
