{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@genfeedai/interfaces": ["../interfaces/src/index.ts"],
      "@genfeedai/interfaces/*": ["../interfaces/src/*"],
      "@genfeedai/types": ["../types/src/index.ts"],
      "@genfeedai/types/*": ["../types/src/*"],
      "@genfeedai/workflow-saas": ["../workflow-saas/src/index.ts"],
      "@genfeedai/workflow-saas/*": ["../workflow-saas/src/*"],
      "@genfeedai/workflow-saas/types": ["../workflow-saas/src/types.ts"],
      "@genfeedai/workflow/*": ["./src/*"],
      "@configs/*": ["../../configs/*"],
      "@contexts/*": ["../contexts/*"],
      "@genfeedai/client": ["../client/dist/index"],
      "@genfeedai/client/*": ["../client/dist/*"],
      "@genfeedai/enums": ["../enums/dist/index"],
      "@genfeedai/enums/*": ["../enums/dist/*"],
      "@helpers/*": ["../helpers/src/*"],
      "@hooks/*": ["../hooks/*"],
      "@models/*": ["../models/*"],
      "@pages/*": ["../pages/*"],
      "@props/*": ["../props/*"],
      "@providers/*": ["../providers/*"],
      "@serializers/*": ["../serializers/src/*"],
      "@services/*": ["../services/*"],
      "@styles/*": ["../styles/*"],
      "@ui-constants/*": ["../ui/constants/*"],
      "@ui/*": ["../ui/*"],
      "@utils/*": ["../utils/*"],
      "@workflow-cloud/*": ["./src/*"],
      "@workflow-saas": ["../workflow-saas/src/index.ts"],
      "@workflow-saas/*": ["../workflow-saas/src/*"],
      "@workflow-saas/types": ["../workflow-saas/src/types.ts"]
    },
    "types": ["react", "react-dom"]
  },
  "exclude": ["node_modules", "dist"],
  "extends": "../tsconfig/nextjs.json",
  "include": ["src/**/*"]
}
