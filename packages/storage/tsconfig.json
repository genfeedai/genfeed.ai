{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "paths": {
      "@genfeedai/config": ["../config/src/index.ts"],
      "@genfeedai/config/*": ["../config/src/*"]
    },
    "resolveJsonModule": true,
    "rootDir": "src",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "es2022",
    "types": ["node"]
  },
  "exclude": ["dist", "node_modules"],
  "include": ["src"],
  "references": [
    {
      "path": "../config"
    }
  ]
}
