{
  "devDependencies": {
    "@sentry/nextjs": "*",
    "@types/node": "*",
    "next": "*",
    "tailwindcss": "*",
    "typescript": "6.0.2"
  },
  "exports": {
    ".": {
      "types": "./next.config.base.ts",
