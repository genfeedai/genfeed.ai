{
  "compilerOptions": {
    "paths": {
      "@genfeedai/helpers/*": ["../helpers/src/*"],
      "@genfeedai/models/*": ["../models/*"],
      "@genfeedai/services/*": ["../services/*"],
      "@genfeedai/utils/*": ["../utils/*"],
      "@props/*": ["./*"],
      "@contexts/*": ["../contexts/*"],
      "@helpers/*": ["../helpers/src/*"],
      "@hooks/*": ["../hooks/*"],
      "@models/*": ["../models/*"],
      "@pages/*": ["../pages/*"],
      "@providers/*": ["../providers/*"],
      "@schemas/*": ["../schemas/*"],
      "@serializers/*": ["../serializers/src/*"],
      "@services/*": ["../services/*"],
      "@styles/*": ["../styles/*"],
      "@ui/*": ["../ui/src/*", "../ui/src/components/*"],
      "@utils/*": ["../utils/*"]
    }
  },
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "**/*.test.ts"],
  "extends": "../tsconfig/base.json",
  "include": ["**/*.ts", "**/*.tsx"]
}
