{
  "dependencies": {
    "@genfeedai/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "tsup": "8.5.1",
    "typescript": "6.0.2"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "default": "./dist/contracts/index.js"
    },
    "./generation": {
      "types": "./dist/generation/index.d.ts",
      "default": "./dist/generation/index.js"
    },
    "./generation/comfyui": {
      "types": "./dist/generation/comfyui/index.d.ts",
      "default": "./dist/generation/comfyui/index.js"
    },
    "./workflows/*": "./workflows/*"
  },
  "files": [
    "dist",
    "workflows",
    "metadata"
  ],
  "license": "AGPL-3.0",
  "main": "./dist/index.js",
  "name": "@genfeedai/workflows",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "directory": "packages/workflows",
    "type": "git",
    "url": "git+https://github.com/genfeedai/genfeed.ai.git"
  },
  "scripts": {
    "build": "tsup src/index.ts src/contracts/index.ts src/generation/index.ts src/generation/comfyui/index.ts --format esm --dts --clean --sourcemap",
    "dev": "tsup src/index.ts src/contracts/index.ts src/generation/index.ts src/generation/comfyui/index.ts --format esm --dts --watch --sourcemap",
    "prepublishOnly": "bun run build",
    "test": "bun test src"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./dist/index.d.ts",
  "version": "0.3.3"
}
