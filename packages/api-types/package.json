{
  "dependencies": {
    "@genfeedai/enums": "workspace:*",
    "zod": "4.4.3"
  },
  "description": "Auto-generated TypeScript types from OpenAPI spec with Zod validation schemas",
  "devDependencies": {
    "openapi-typescript": "7.13.0",
    "typescript": "6.0.3"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./contracts": {
      "types": "./dist/contracts/index.d.ts",
      "default": "./dist/contracts/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "license": "MIT",
  "main": "./dist/index.js",
  "name": "@genfeedai/api-types",
  "private": false,
  "type": "module",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "directory": "api-types",
    "type": "git",
    "url": "git+https://github.com/genfeedai/packages.git"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "dev": "tsc --watch",
    "generate": "bun run scripts/generate.ts --skip-on-error",
    "generate:strict": "bun run scripts/generate.ts",
    "prepublishOnly": "bun run build",
    "type-check": "tsc --noEmit"
  },
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "version": "1.0.1"
}
