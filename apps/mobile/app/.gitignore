# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# IDE - VSCode
.vscode/*
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.example
# Note: .vscode/settings.json is personal, use .vscode/settings.json.example as template

# IDE - Cursor
.cursor/settings.json
# Note: .cursor/commands/* are team-shared slash commands (committed)

# IDE - Other
.idea/
*.swp
*.swo
