    "react-native-web": "0.21.2",
    "react-native-webview": "14.0.1"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/react-native": "14.0.1",
    "@types/react": "19.2.16",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.5.0",
    "eslint-config-expo": "56.0.4",
    "jsdom": "29.1.1",
    "typescript": "6.0.2",
    "vitest": "4.1.9"
  },
  "main": "expo-router/entry",
  "name": "@genfeedai/mobile",
  "overrides": {
    "typescript": "6.0.2"
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "type": "module",
  "scripts": {
    "android": "expo start --android",
    "cache:clear": "rm -rf node_modules .expo .expo-shared .next dist build",
    "deps:update": "bunx npm-check-updates -u --reject typescript && bun install",
    "ios": "expo start --ios",
    "lint": "bunx expo lint",
    "lint:fix": "bunx expo lint --fix",
    "prepare:deploy": "bun run lint:fix && bun run type-check",
    "start": "expo start",
    "start:dev": "expo start --web",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "version": "1.0.0"
}
