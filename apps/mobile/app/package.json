{
  "dependencies": {
    "@expo/vector-icons": "15.1.1",
    "@genfeedai/ui": "workspace:*",
    "@react-native-async-storage/async-storage": "3.1.1",
    "@react-native-community/netinfo": "12.0.1",
    "@sentry/react-native": "8.17.2",
    "@shopify/flash-list": "2.3.2",
    "expo": "57.0.4",
    "expo-auth-session": "^57.0.2",
    "expo-blur": "57.0.0",
    "expo-constants": "57.0.3",
    "expo-device": "57.0.0",
    "expo-font": "57.0.0",
    "expo-haptics": "57.0.0",
    "expo-image": "57.0.0",
    "expo-linking": "57.0.2",
    "expo-notifications": "57.0.3",
    "expo-router": "57.0.4",
    "expo-secure-store": "57.0.0",
    "expo-splash-screen": "57.0.2",
    "expo-status-bar": "57.0.0",
    "expo-symbols": "57.0.0",
    "expo-system-ui": "57.0.0",
    "expo-web-browser": "57.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "3.0.2",
    "react-native-reanimated": "4.5.1",
    "react-native-safe-area-context": "5.8.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "0.21.2",
    "react-native-webview": "14.0.1"
  },
  "devDependencies": {
    "@babel/core": "8.0.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/react-native": "14.0.1",
    "@types/react": "19.2.17",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.6.0",
    "eslint-config-expo": "57.0.0",
    "jsdom": "29.1.1",
    "typescript": "6.0.2",
    "vitest": "4.1.10"
  },
  "main": "expo-router/entry",
  "name": "@genfeedai/mobile",
  "overrides": {
    "typescript": "6.0.2"
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "type": "module",
  "scripts": {
    "android": "expo start --android",
    "cache:clear": "rm -rf node_modules .expo .expo-shared .next dist build",
    "deps:update": "bunx npm-check-updates -u --reject typescript && bun install",
    "ios": "expo start --ios",
    "lint": "bunx expo lint",
    "lint:fix": "bunx expo lint --fix",
    "prepare:deploy": "bun run lint:fix && bun run type-check",
    "start": "expo start",
    "start:dev": "expo start --web",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "version": "1.0.0"
}
