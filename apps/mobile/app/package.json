    "expo-haptics": "56.0.3",
    "expo-image": "56.0.9",
    "expo-linking": "56.0.13",
    "expo-notifications": "56.0.15",
    "expo-router": "56.2.8",
    "expo-secure-store": "56.0.4",
    "expo-splash-screen": "56.0.10",
    "expo-status-bar": "56.0.4",
    "expo-symbols": "56.0.5",
    "expo-system-ui": "56.0.5",
    "expo-web-browser": "56.0.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "3.0.0",
    "react-native-reanimated": "4.4.0",
    "react-native-safe-area-context": "5.8.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "0.21.2",
    "react-native-webview": "13.16.1"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/react-native": "13.3.3",
    "@types/react": "19.2.16",
    "@vitest/coverage-v8": "4.1.8",
    "eslint": "10.4.1",
    "eslint-config-expo": "56.0.4",
    "jsdom": "29.1.1",
    "typescript": "6.0.2",
    "vitest": "4.1.8"
  },
  "main": "expo-router/entry",
  "name": "@genfeedai/mobile",
  "overrides": {
    "typescript": "6.0.2"
  },
  "packageManager": "bun@1.3.14",
  "private": true,
  "type": "module",
  "scripts": {
    "android": "expo start --android",
    "cache:clear": "rm -rf node_modules .expo .expo-shared .next dist build",
    "deps:update": "bunx npm-check-updates -u --reject typescript && bun install",
    "ios": "expo start --ios",
    "lint": "bunx expo lint",
    "lint:fix": "bunx expo lint --fix",
    "prepare:deploy": "bun run lint:fix && bun run type-check",
    "start": "expo start",
    "start:dev": "expo start --web",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "tsc --noEmit"
  },
  "version": "1.0.0"
}
