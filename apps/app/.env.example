# Port (Next.js reads PORT env var automatically)
PORT=3000

# Local development endpoints
NEXT_PUBLIC_API_ENDPOINT=http://local.genfeed.ai:3010/v1
NEXT_PUBLIC_WS_ENDPOINT=http://local.genfeed.ai:3013
NEXT_PUBLIC_APPS_APP_ENDPOINT=http://local.genfeed.ai:3000

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Clerk - Redirect configuration
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/onboarding/post-signup
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/onboarding/post-signup
CLERK_SIGN_UP_FORCE_REDIRECT_URL=/onboarding/post-signup

# Sentry
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# OAuth
MEDIUM_REDIRECT_URI=http://local.genfeed.ai:3000/auth/medium/callback

# CDN
NEXT_PUBLIC_CDN_URL=https://staging-cdn.genfeed.ai
