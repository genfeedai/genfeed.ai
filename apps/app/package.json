{
  "dependencies": {
    "@fullcalendar/timegrid": "6.1.21",
    "@genfeedai/agent": "*",
    "@genfeedai/api-types": "*",
    "@genfeedai/auth-client": "*",
    "@genfeedai/client": "*",
    "@genfeedai/config": "*",
    "@genfeedai/constants": "*",
    "@genfeedai/core": "*",
    "@genfeedai/desktop-contracts": "*",
    "@genfeedai/enums": "*",
    "@genfeedai/helpers": "*",
    "@genfeedai/interfaces": "*",
    "@genfeedai/next-config": "*",
    "@genfeedai/types": "*",
    "@genfeedai/workflow-saas": "*",
    "@genfeedai/workflow-ui": "*",
    "@radix-ui/react-collapsible": "1.1.16",
    "@remotion/player": "4.0.486",
    "@tanstack/react-query": "5.101.2",
    "@tiptap/core": "3.27.3",
    "@tiptap/extension-mention": "3.27.3",
    "@tiptap/extension-placeholder": "3.27.3",
    "@tiptap/extensions": "3.27.3",
    "@tiptap/pm": "3.27.3",
    "@tiptap/react": "3.27.3",
    "@tiptap/starter-kit": "3.27.3",
    "@tiptap/suggestion": "3.27.3",
    "@xyflow/react": "12.11.2",
    "clsx": "2.1.1",
    "next": "16.2.10",
    "posthog-js": "1.398.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "remotion": "4.0.486",
    "tailwind-merge": "3.6.0",
    "yet-another-react-lightbox": "3.32.1",
    "zundo": "2.3.0",
    "zustand": "5.0.14"
  },
  "description": "Genfeed Content Hub - Unified content management, publishing, and analytics",
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.2"
  },
  "name": "@genfeedai/app",
  "private": true,
  "type": "module",
  "scripts": {
    "analyze": "ANALYZE=true next build",
    "analyze:browser": "ANALYZE=true BUNDLE_ANALYZE=browser next build",
    "analyze:server": "ANALYZE=true BUNDLE_ANALYZE=server next build",
    "build": "next build --turbopack",
    "deps:update": "bunx npm-check-updates -u --reject typescript && bun install",
    "dev": "NODE_OPTIONS='--max-old-space-size=4096 --disable-warning=DEP0169' next dev --turbopack",
    "dev:direct": "NODE_OPTIONS='--max-old-space-size=4096 --disable-warning=DEP0169' next dev --turbopack",
    "dev:portless": "portless run --name app.genfeed bun run dev:direct",
    "lint": "biome check app src packages tests instrumentation.ts jsx-compat.d.ts next.config.ts next.config.test.ts package.json postcss.config.mjs proxy.ts proxy.test.ts remotion.d.ts sentry.edge.config.ts sentry.server.config.ts tailwind.config.ts tsconfig.json tsconfig.test.json vercel.json",
    "start": "next start",
    "test": "vitest run --config ./vitest.config.mts --maxWorkers=2",
    "test:cov": "vitest run --coverage --config ./vitest.config.mts --maxWorkers=2",
    "test:cov:shard": "vitest run --coverage --config ./vitest.config.mts --maxWorkers=2",
    "test:watch": "vitest --config ./vitest.config.mts",
    "type-check": "rm -rf .next && next typegen && tsc --noEmit"
  },
  "version": "1.0.0"
}
