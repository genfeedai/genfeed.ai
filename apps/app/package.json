  "description": "Genfeed Content Hub - Unified content management, publishing, and analytics",
  "name": "@genfeedai/app",
  "private": true,
  "scripts": {
    "analyze": "ANALYZE=true next build",
    "analyze:browser": "ANALYZE=true BUNDLE_ANALYZE=browser next build",
    "analyze:server": "ANALYZE=true BUNDLE_ANALYZE=server next build",
    "build": "next build",
    "deps:update": "bunx npm-check-updates -u --reject typescript && bun install",
    "dev": "NODE_OPTIONS='--max-old-space-size=4096 --disable-warning=DEP0169' next dev --turbopack --port 3102",
    "lint": "biome check .",
    "start": "next start --port 3102",
    "test": "vitest run --config ../vitest.config.mts",
    "test:cov": "vitest run --coverage --config ../vitest.config.mts",
    "test:watch": "vitest --config ../vitest.config.mts",
    "type-check": "rm -rf .next && next typegen && tsc --noEmit"
  },
  "version": "1.0.0",
  "devDependencies": {
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "typescript": "6.0.2"
  }
}
