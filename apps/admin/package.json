{
  "dependencies": {
    "@genfeedai/agent": "workspace:*",
    "@genfeedai/types": "workspace:*",
    "@genfeedai/constants": "workspace:*",
    "@genfeedai/helpers": "workspace:*",
    "@genfeedai/interfaces": "workspace:*",
    "@genfeedai/next-config": "workspace:*",
    "@tiptap/core": "3.22.1",
    "@tiptap/extension-image": "3.22.1",
    "@tiptap/extension-link": "3.22.1",
    "@tiptap/extension-mention": "3.22.1",
    "@tiptap/extension-placeholder": "3.22.1",
    "@tiptap/extensions": "3.22.1",
    "@tiptap/pm": "3.22.1",
    "@tiptap/react": "3.22.1",
    "@tiptap/starter-kit": "3.22.1",
    "@tiptap/suggestion": "3.22.1",
    "clsx": "2.1.1",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.5.0"
  },
  "description": "Genfeed Admin - System administration dashboard for user management and platform settings",
  "name": "@genfeedai/admin",
  "private": true,
  "scripts": {
    "analyze": "ANALYZE=true next build",
    "analyze:browser": "ANALYZE=true BUNDLE_ANALYZE=browser next build",
    "analyze:server": "ANALYZE=true BUNDLE_ANALYZE=server next build",
    "build": "next build",
    "deps:update": "bunx npm-check-updates -u --reject typescript && bun install",
    "dev": "NODE_OPTIONS='--max-old-space-size=4096 --disable-warning=DEP0169' next dev --turbopack --port 3101",
    "lint": "biome check .",
    "start": "next start --port 3101",
    "test": "vitest run --config ../vitest.config.mts",
    "test:cov": "vitest run --coverage --config ../vitest.config.mts",
    "test:watch": "vitest --config ../vitest.config.mts",
    "type-check": "rm -rf .next/types && next typegen && tsc --noEmit"
  },
  "version": "1.0.0"
}
