{
  "dependencies": {
    "@genfeedai/agent": "*",
    "@genfeedai/constants": "*",
    "@genfeedai/helpers": "*",
    "@genfeedai/interfaces": "*",
    "@genfeedai/next-config": "*",
    "@genfeedai/types": "*",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@tiptap/core": "3.22.2",
    "@tiptap/extension-image": "3.22.2",
    "@tiptap/extension-link": "3.22.2",
    "@tiptap/extension-mention": "3.22.2",
    "@tiptap/extension-placeholder": "3.22.2",
    "@tiptap/extensions": "3.22.2",
    "@tiptap/pm": "3.22.2",
    "@tiptap/react": "3.22.2",
    "@tiptap/starter-kit": "3.22.2",
    "@tiptap/suggestion": "3.22.2",
    "clsx": "2.1.1",
    "next": "16.2.2",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "3.5.0"
  },
  "description": "Genfeed Admin - System administration dashboard for user management and platform settings",
  "name": "@genfeedai/admin",
  "private": true,
  "scripts": {
    "analyze": "ANALYZE=true next build",
    "analyze:browser": "ANALYZE=true BUNDLE_ANALYZE=browser next build",
    "analyze:server": "ANALYZE=true BUNDLE_ANALYZE=server next build",
    "build": "next build",
    "deps:update": "bunx npm-check-updates -u --reject typescript && bun install",
    "dev": "NODE_OPTIONS='--max-old-space-size=4096 --disable-warning=DEP0169' next dev --turbopack",
    "lint": "biome check .",
    "start": "next start",
    "test": "vitest run --config ../vitest.config.mts",
    "test:cov": "vitest run --coverage --config ../vitest.config.mts",
    "test:watch": "vitest --config ../vitest.config.mts",
    "type-check": "rm -rf .next/types && next typegen && tsc --noEmit"
  },
  "version": "1.0.0",
  "devDependencies": {
    "@types/node": "25.5.2",
    "@types/react": "19.2.14",
    "typescript": "6.0.2"
  }
}
