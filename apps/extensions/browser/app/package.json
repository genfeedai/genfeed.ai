{
  "author": "vincent@genfeed.ai",
  "dependencies": {
    "@genfeedai/auth-client": "workspace:*",
    "@genfeedai/client": "workspace:*",
    "@genfeedai/constants": "workspace:*",
    "@genfeedai/enums": "workspace:*",
    "@genfeedai/helpers": "workspace:*",
    "@genfeedai/interfaces": "workspace:*",
    "@genfeedai/next-config": "workspace:*",
    "@genfeedai/ui": "workspace:*",
    "@genfeedai/utils": "workspace:*",
    "@plasmohq/storage": "1.15.0",
    "@radix-ui/react-collapsible": "1.1.16",
    "@radix-ui/react-select": "2.3.3",
    "@radix-ui/react-slot": "1.3.0",
    "@sentry/browser": "10.64.0",
    "axios": "1.18.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "lucide-react": "1.23.0",
    "plasmo": "0.90.5",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0",
    "zustand": "5.0.14"
  },
  "description": "Genfeed.ai - Generate (good) AI content for your business",
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.7.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/chrome": "0.2.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "autoprefixer": "10.5.2",
    "jsdom": "29.1.1",
    "postcss": "8.5.16",
    "prettier": "3.9.4",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.2",
    "vitest": "4.1.10"
  },
  "displayName": "Extension genfeed ai",
  "exports": {
    "./background": "./src/background.ts",
    "./content": "./src/content.ts",
    "./popup": "./src/popup.tsx",
    "./sidepanel": "./src/sidepanel.tsx"
  },
  "manifest": {
    "host_permissions": [
      "http://genfeed.localhost/*",
      "http://local.genfeed.ai/*",
      "https://app.genfeed.ai/*",
      "https://genfeed.ai/*",
      "https://*.twitter.com/*",
      "https://*.x.com/*",
      "https://*.youtube.com/*",
      "https://*.instagram.com/*",
      "https://*.reddit.com/*",
      "https://*.facebook.com/*",
      "https://*.tiktok.com/*",
      "https://*.linkedin.com/*",
      "https://api.genfeed.ai/*"
    ],
    "permissions": [
      "cookies",
      "storage",
      "tabs",
      "scripting",
      "activeTab",
      "sidePanel"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    }
  },
  "name": "@genfeedai/extension-browser",
  "packageManager": "bun@1.3.14",
  "type": "module",
  "scripts": {
    "build": "npm exec plasmo build",
    "cache:clear": "./scripts/bash/cache-clear.sh",
    "deps:update": "bunx npm-check-updates -u --reject typescript,tailwindcss && bun install",
    "dev": "npm exec plasmo dev",
    "dev:debug": "PLASMO_PUBLIC_ENV=development npm exec plasmo dev",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write .",
    "package": "npm exec plasmo package",
    "prepare:deploy": "bun run format:fix && bun run build",
    "start:dev": "npm exec plasmo dev",
    "test": "npx vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "version": "1.0.0"
}
