# bun configuration for optimal monorepo performance

# Use hoisted node_modules structure for faster installs and less disk space
node-linker=hoisted

# Automatically install peer dependencies
auto-install-peers=true

# Prefer packages from workspace over external registry
prefer-workspace-packages=true

# Enable strict peer dependencies checking
strict-peer-dependencies=false

# Faster lockfile resolution
resolution-mode=highest

# Use hard links when possible to save disk space
package-import-method=hardlink

# Disable package verification for faster installs (use with caution)
# verify-store-integrity=false

# Increase network concurrency for faster downloads
network-concurrency=16

# Cache directory configuration (optional - uses default if not set)
# store-dir=~/.bun-store
