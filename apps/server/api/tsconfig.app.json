{
  "compilerOptions": {
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "outDir": "../dist/apps/api",
    "rootDir": "./src",
    "paths": {
      "@api/*": ["./src/*"],
      "@files/*": ["../files/src/*"],
      "@libs/*": ["../../../packages/libs/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.e2e-spec.ts"
  ],
  "extends": "../tsconfig.json",
  "include": ["src/**/*", "src/**/*.d.ts"]
}
