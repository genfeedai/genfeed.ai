# ============================================
# API APP - GENERATED OUTPUT REFERENCE
# ============================================
# Canonical source of truth: `../../../.env.local|.env.staging|.env.production`
# Generate this file with `bun run env:sync <local|staging|production>`.
# Keep real values in the root env files, not here.
# ============================================

# ===== SHARED BASE (.env) =====
# These go in .env - same value across all environments

# --------------------------------------------
# Server Configuration
# --------------------------------------------
SERVICE_NAME=api-genfeed-ai

# --------------------------------------------
# Marketplace (extracted service)
# --------------------------------------------
MARKETPLACE_API_URL=http://localhost:3200

# --------------------------------------------
# AWS
# --------------------------------------------
AWS_REGION=us-west-1

# --------------------------------------------
# Direct LLM Provider Keys (for Agent — bypasses OpenRouter)
# --------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
OPENAI_API_KEY=sk-your-openai-key
OPENAI_CODEX_REDIRECT_URI=http://local.genfeed.ai:3102/oauth/openai

# --------------------------------------------
# AI Voice Services
# --------------------------------------------
ELEVENLABS_API_KEY=sk_your_elevenlabs_api_key
ELEVENLABS_MODEL=eleven_turbo_v2_5

# --------------------------------------------
# Stripe (shared non-secret values)
# --------------------------------------------
STRIPE_API_VERSION=2025-09-30.clover
STRIPE_PAYG_CREDITS=1000
STRIPE_MONTHLY_CREDITS=30000
STRIPE_YEARLY_CREDITS=500000
STRIPE_COUPON_CREDITS_PACKS_V2_PRO=CREATOR5
STRIPE_COUPON_CREDITS_PACKS_V2_ENTERPRISE=PRO15
STRIPE_BYOK_FEE_PERCENTAGE=5
STRIPE_BYOK_FREE_THRESHOLD=500

# --------------------------------------------
# AI Image Generation
# --------------------------------------------
LEONARDO_KEY=your_leonardo_api_key
KLINGAI_KEY=your_klingai_api_key
KLINGAI_SECRET=your_klingai_secret
KLINGAI_MODEL=kling-v2
HEYGEN_KEY=your_heygen_api_key

# --------------------------------------------
# Social Media (shared config)
# --------------------------------------------
FACEBOOK_GRAPH_URL=https://graph.facebook.com
FACEBOOK_API_VERSION=v24.0
INSTAGRAM_GRAPH_URL=https://graph.instagram.com
INSTAGRAM_API_VERSION=v24.0
REDDIT_USER_AGENT=GenFeed/1.0

# --------------------------------------------
# News API
# --------------------------------------------
NEWS_API_KEY=your_news_api_key
NEWS_API_URL=https://newsapi.org/v2/everything

# --------------------------------------------
# Hedra
# --------------------------------------------
HEDRA_KEY=

# --------------------------------------------
# Replicate (Model Training)
# --------------------------------------------
REPLICATE_KEY=r8_your_replicate_api_key
REPLICATE_TARGET_FPS=60
REPLICATE_TARGET_RESOLUTION=1080p
REPLICATE_MODELS_TRAINER=replicate/fast-flux-trainer:model_version_hash
REPLICATE_OWNER=your_replicate_username
REPLICATE_MODEL_VISIBILITY=private
REPLICATE_MODEL_HARDWARE=gpu-t4
TRAINING_TRAINING_CREDITS_COST=5000
TRAINING_CUSTOM_MODEL_CREDITS_COST=10

# --------------------------------------------
# Blockchain
# --------------------------------------------
SOLANA_KEY=
SOLANA_URL=https://api.mainnet-beta.solana.com

# --------------------------------------------
# GIF/Media Services
# --------------------------------------------
GIPHY_API_KEY=

# ===== LOCAL OVERRIDES (.env.local) =====
# These go in .env.local - values specific to local development

# --------------------------------------------
# Server
# --------------------------------------------
PORT=3001

# --------------------------------------------
# Application URLs
# --------------------------------------------
GENFEEDAI_APP_URL=http://local.genfeed.ai:3102
GENFEEDAI_PUBLIC_URL=http://local.genfeed.ai:3105
GENFEEDAI_API_URL=http://local.genfeed.ai:3001
GENFEEDAI_CDN_URL=https://staging-cdn.genfeed.ai
GENFEEDAI_API_KEY=your-internal-service-api-key

# --------------------------------------------
# Microservices URLs
# --------------------------------------------
GENFEEDAI_MICROSERVICES_FILES_URL=http://local.genfeed.ai:3005
GENFEEDAI_MICROSERVICES_MCP_URL=http://local.genfeed.ai:3006
GENFEEDAI_MICROSERVICES_NOTIFICATIONS_URL=http://local.genfeed.ai:3007

# --------------------------------------------
# GrowthBook Feature Flags
# --------------------------------------------
# Use GrowthBook Cloud for local development. Create an SDK connection in
# app.growthbook.io and copy the CDN host + SDK client key into these values.
GROWTHBOOK_API_HOST=https://cdn.growthbook.io
GROWTHBOOK_CLIENT_KEY=sdk-your-growthbook-client-key

# --------------------------------------------
# GPU Fleet (Tailscale private network)
# --------------------------------------------
GPU_IMAGES_URL=http://100.x.x.x:8189
GPU_VIDEOS_URL=http://100.x.x.x:8189
GPU_VOICES_URL=http://100.x.x.x:8189

# --------------------------------------------
# Webhooks
# --------------------------------------------
GENFEEDAI_WEBHOOKS_URL=https://your-ngrok-url.ngrok-free.app

# --------------------------------------------
# AWS (dev credentials)
# --------------------------------------------
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=your-s3-bucket-name

# --------------------------------------------
# MongoDB (all named databases derived automatically from MONGODB_URI)
# --------------------------------------------
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/genfeed

# --------------------------------------------
# Clerk Authentication
# --------------------------------------------
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_WEBHOOK_SIGNING_SECRET=whsec_your_webhook_signing_secret

# --------------------------------------------
# Chrome Extension
# --------------------------------------------
CHROME_EXTENSION_ID=

# --------------------------------------------
# Bull Board Admin UI
# --------------------------------------------
BULL_BOARD_AUTH_TOKEN=

# --------------------------------------------
# Stripe (test keys)
# --------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SIGNING_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PRICE_PAYG=price_your_payg_price_id
STRIPE_PRICE_SUBSCRIPTION_CREATOR_MONTHLY=price_your_creator_monthly_id
STRIPE_PRICE_SUBSCRIPTION_PRO_MONTHLY=price_your_pro_monthly_id
STRIPE_PRICE_SUBSCRIPTION_SCALE_MONTHLY=price_your_scale_monthly_id
STRIPE_PRICE_SUBSCRIPTION_ENTERPRISE_MONTHLY=price_your_enterprise_monthly_id
STRIPE_PRICE_SKILLS_PRO=price_your_skills_pro_id

# --------------------------------------------
# YouTube API
# --------------------------------------------
YOUTUBE_CLIENT_ID=your_youtube_client_id
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret
YOUTUBE_REDIRECT_URI=http://local.genfeed.ai:3102/oauth/youtube

# --------------------------------------------
# Social Media (dev app credentials)
# --------------------------------------------
TIKTOK_CLIENT_KEY=your_tiktok_client_key
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret

INSTAGRAM_REDIRECT_URI=https://your-ngrok-url.ngrok-free.app/oauth/instagram
