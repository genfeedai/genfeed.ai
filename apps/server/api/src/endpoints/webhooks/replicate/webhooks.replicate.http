########################################
# Replicate Webhooks - Training
########################################

### Replicate Training Success
# Training completed successfully
POST {{baseUrl}}/webhooks/replicate/callback
Content-Type: application/json
webhook-id: whsec_test128
webhook-timestamp: 1234567894
webhook-signature: v1,test_signature_here

{
  "id": "{{testExternalId}}",
  "status": "succeeded",
  "version": "model_version_abc123",
  "output": {
    "version": "owner/model:abc123def456"
  },
  "error": null
}


### Replicate Training Failed
POST {{baseUrl}}/webhooks/replicate/callback
Content-Type: application/json
webhook-id: whsec_test129
webhook-timestamp: 1234567895
webhook-signature: v1,test_signature_here

{
  "id": "{{testExternalId}}",
  "status": "failed",
  "error": "Training failed: Insufficient training data",
  "input": {
    "input_images": "https://example.com/training-data.zip"
  }
}


########################################
# Replicate Webhooks - With Metadata
########################################

### Replicate with Webhook Metadata
# Processes metadata-based webhook
POST {{baseUrl}}/webhooks/replicate/callback
Content-Type: application/json
webhook-id: whsec_test130
webhook-timestamp: 1234567896
webhook-signature: v1,test_signature_here

{
  "id": "pred_abc123",
  "model": "google-imagen-3",
  "status": "succeeded",
  "output": "https://example.com/images/metadata-output.jpg",
  "webhook_metadata": {
    "metadataId": "metadata_{{testExternalId}}",
    "userId": "user_123"
  }
}


