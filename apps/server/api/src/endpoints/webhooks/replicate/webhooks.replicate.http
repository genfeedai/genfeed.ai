### Genfeed API - Replicate Webhook Endpoint
### This endpoint is PUBLIC but validates webhook signatures in production

@import ../../../../../http/_environment.http

########################################
# Replicate Webhooks - Image Generation
########################################

### Replicate Image Generation Success (Single Output)
# Validates webhook signature with headers
POST {{baseUrl}}/webhooks/replicate/callback
Content-Type: application/json
webhook-id: whsec_test123
webhook-timestamp: 1234567890
webhook-signature: v1,test_signature_here

{
  "id": "{{testExternalId}}",
  "model": "google-imagen-3",
  "version": "v1",
  "status": "succeeded",
  "output": "https://example.com/images/output.jpg",
  "error": null
}


### Replicate Image Generation Success (Multiple Outputs)
# For models that support multiple outputs
POST {{baseUrl}}/webhooks/replicate/callback
Content-Type: application/json
webhook-id: whsec_test124
webhook-timestamp: 1234567890
webhook-signature: v1,test_signature_here

{
  "id": "{{testExternalId}}",
  "model": "google-imagen-4",
  "version": "v1",
  "status": "succeeded",
  "output": [
    "https://example.com/images/output1.jpg",
    "https://example.com/images/output2.jpg",
    "https://example.com/images/output3.jpg"
  ],
  "error": null
}


