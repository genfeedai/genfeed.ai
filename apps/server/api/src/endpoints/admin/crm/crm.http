### Genfeed API - Admin CRM Endpoints
### Manage leads, companies, tasks, financials, analytics, and margins
### All endpoints require IP whitelist (IpWhitelistGuard)

########################################
# Leads
########################################

### List All Leads
GET {{apiBaseUrl}}/admin/crm/leads
Authorization: Bearer {{bearerToken}}


### List Leads by Status
# Status values: new, contacted, qualified, proposal, negotiation, won, lost, churned
GET {{apiBaseUrl}}/admin/crm/leads?status=qualified
Authorization: Bearer {{bearerToken}}


### Get Lead by ID
GET {{apiBaseUrl}}/admin/crm/leads/{{testLeadId}}
Authorization: Bearer {{bearerToken}}


### Create Lead
POST {{apiBaseUrl}}/admin/crm/leads
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "name": "Jane Smith",
  "email": "jane@example.com",
  "company": "Acme Inc",
  "source": "website",
  "status": "new",
  "notes": "Interested in enterprise plan"
}


### Update Lead
PATCH {{apiBaseUrl}}/admin/crm/leads/{{testLeadId}}
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "status": "qualified",
  "notes": "Had initial call, interested in annual plan"
}


### Delete Lead (Soft Delete)
DELETE {{apiBaseUrl}}/admin/crm/leads/{{testLeadId}}
Authorization: Bearer {{bearerToken}}


########################################
# Companies
########################################

### List All Companies
GET {{apiBaseUrl}}/admin/crm/companies
Authorization: Bearer {{bearerToken}}


### Get Company by ID
GET {{apiBaseUrl}}/admin/crm/companies/{{testCompanyId}}
Authorization: Bearer {{bearerToken}}


### Create Company
POST {{apiBaseUrl}}/admin/crm/companies
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "name": "Acme Inc",
  "domain": "acme.com",
  "industry": "technology",
  "size": "50-200",
  "website": "https://acme.com"
}


### Update Company
PATCH {{apiBaseUrl}}/admin/crm/companies/{{testCompanyId}}
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "name": "Acme Inc (Updated)",
  "industry": "saas"
}


########################################
# Tasks
########################################

### List All Tasks
GET {{apiBaseUrl}}/admin/crm/tasks
Authorization: Bearer {{bearerToken}}


### Create Task
POST {{apiBaseUrl}}/admin/crm/tasks
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "title": "Follow up with Acme Inc",
  "description": "Schedule demo for enterprise plan",
  "dueDate": "2026-03-01T10:00:00Z",
  "priority": "high",
  "status": "pending"
}


### Update Task
PATCH {{apiBaseUrl}}/admin/crm/tasks/{{testCrmTaskId}}
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "status": "completed",
  "notes": "Demo scheduled for next week"
}


### Delete Task (Soft Delete)
DELETE {{apiBaseUrl}}/admin/crm/tasks/{{testCrmTaskId}}
Authorization: Bearer {{bearerToken}}


########################################
# Financial
########################################

### List Cost Records
GET {{apiBaseUrl}}/admin/crm/costs
Authorization: Bearer {{bearerToken}}


### Create Cost Record
POST {{apiBaseUrl}}/admin/crm/costs
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "category": "infrastructure",
  "amount": 2500.00,
  "description": "AWS monthly bill",
  "date": "2026-02-01T00:00:00Z",
  "recurring": true
}


### List Revenue Records
GET {{apiBaseUrl}}/admin/crm/revenue
Authorization: Bearer {{bearerToken}}


########################################
# Analytics
########################################

### Get CRM Analytics (Default 30 days)
GET {{apiBaseUrl}}/admin/crm/analytics
Authorization: Bearer {{bearerToken}}


### Get CRM Analytics (Custom Days)
GET {{apiBaseUrl}}/admin/crm/analytics?days=90
Authorization: Bearer {{bearerToken}}


########################################
# Margins
########################################

### Get Margin Summary
GET {{apiBaseUrl}}/admin/crm/margins/summary
Authorization: Bearer {{bearerToken}}


### Get Monthly Margin Breakdown (Current Year)
GET {{apiBaseUrl}}/admin/crm/margins/monthly
Authorization: Bearer {{bearerToken}}


### Get Monthly Margin Breakdown (Specific Year)
GET {{apiBaseUrl}}/admin/crm/margins/monthly?year=2025
Authorization: Bearer {{bearerToken}}


### Get Cost/Revenue Margins
GET {{apiBaseUrl}}/admin/crm/margins
Authorization: Bearer {{bearerToken}}


########################################
# Test Cases
########################################

### Test: Invalid Lead ID
GET {{apiBaseUrl}}/admin/crm/leads/invalid-id
Authorization: Bearer {{bearerToken}}


### Test: Lead Not Found
GET {{apiBaseUrl}}/admin/crm/leads/507f1f77bcf86cd799439011
Authorization: Bearer {{bearerToken}}


### Test: Create Lead Without Required Fields
POST {{apiBaseUrl}}/admin/crm/leads
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "name": ""
}


### Test: Unauthorized Access (No Token)
GET {{apiBaseUrl}}/admin/crm/leads
