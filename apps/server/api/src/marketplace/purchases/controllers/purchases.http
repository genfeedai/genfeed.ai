### Genfeed API - Marketplace Purchases Endpoints
### Handle checkout, claims, purchases, downloads, and installations
### Protected by ClerkGuard

########################################
# Checkout
########################################

### Create Checkout Session (Stripe)
POST {{apiBaseUrl}}/marketplace/listings/{{testListingId}}/checkout
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "successUrl": "https://marketplace.genfeed.ai/checkout/success",
  "cancelUrl": "https://marketplace.genfeed.ai/checkout/cancel"
}


### Get Checkout Session Status
GET {{apiBaseUrl}}/marketplace/checkout/{{testCheckoutSessionId}}
Authorization: Bearer {{bearerToken}}


### Claim Free Listing
POST {{apiBaseUrl}}/marketplace/listings/{{testListingId}}/claim
Authorization: Bearer {{bearerToken}}


########################################
# Purchases
########################################

### Get My Purchases
GET {{apiBaseUrl}}/marketplace/purchases
Authorization: Bearer {{bearerToken}}


### Get My Purchases with Pagination
GET {{apiBaseUrl}}/marketplace/purchases?page=1&limit=20
Authorization: Bearer {{bearerToken}}


### Get Specific Purchase
GET {{apiBaseUrl}}/marketplace/purchases/{{testPurchaseId}}
Authorization: Bearer {{bearerToken}}


### Get Download URL for Purchase
GET {{apiBaseUrl}}/marketplace/purchases/{{testPurchaseId}}/download
Authorization: Bearer {{bearerToken}}


### Install Purchase to Workspace
POST {{apiBaseUrl}}/marketplace/purchases/{{testPurchaseId}}/install
Authorization: Bearer {{bearerToken}}


########################################
# Ownership
########################################

### Check Listing Ownership
GET {{apiBaseUrl}}/marketplace/listings/{{testListingId}}/ownership
Authorization: Bearer {{bearerToken}}


########################################
# Test Cases
########################################

### Test: Checkout Non-Existent Listing
POST {{apiBaseUrl}}/marketplace/listings/507f1f77bcf86cd799439011/checkout
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "successUrl": "https://example.com/success",
  "cancelUrl": "https://example.com/cancel"
}


### Test: Invalid Purchase ID
GET {{apiBaseUrl}}/marketplace/purchases/invalid-id
Authorization: Bearer {{bearerToken}}


### Test: Unauthorized Access
GET {{apiBaseUrl}}/marketplace/purchases
