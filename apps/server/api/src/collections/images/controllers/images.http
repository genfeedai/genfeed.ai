### Genfeed API - Images Collection Endpoints
### Manage AI image generation and CRUD operations
### Supports: OpenAI DALL-E, LeonardoAI, KlingAI, SDXL, Google Imagen, Replicate models

########################################
# Latest Images
########################################

### Get Latest Images
# Get the most recent images for the current user (up to 50)
# Includes both user images and default images
# Cached for 5 minutes
GET {{apiBaseUrl}}/images/latest?limit=10
Authorization: Bearer {{bearerToken}}


### Get Latest Images (Max Limit)
GET {{apiBaseUrl}}/images/latest?limit=50
Authorization: Bearer {{bearerToken}}


########################################
# List & Filter Images
########################################

### Get All Images (Paginated)
# Default: page=1, limit=20
# Includes user images and default images
GET {{apiBaseUrl}}/images
Authorization: Bearer {{bearerToken}}


### Get Images with Pagination
GET {{apiBaseUrl}}/images?page=2&limit=10
Authorization: Bearer {{bearerToken}}


### Filter Images by Status
# Status values: processing, completed, failed, uploaded
# Can use comma-separated values: status=completed,uploaded
GET {{apiBaseUrl}}/images?status=completed&page=1&limit=20
Authorization: Bearer {{bearerToken}}


### Filter Images by Format
# Format values: square, landscape, portrait
GET {{apiBaseUrl}}/images?format=square&page=1&limit=10
Authorization: Bearer {{bearerToken}}


### Filter Images by Folder
# Get images in a specific folder
GET {{apiBaseUrl}}/images?folder={{testFolderId}}&page=1&limit=20
Authorization: Bearer {{bearerToken}}


### Get Root Images Only (No Parent)
GET {{apiBaseUrl}}/images?parent=null
Authorization: Bearer {{bearerToken}}


### Filter Images by Training
# Get images associated with a specific training
GET {{apiBaseUrl}}/images?training={{testTrainingId}}
Authorization: Bearer {{bearerToken}}


### Search Images by Label/Description
GET {{apiBaseUrl}}/images?search=landscape&page=1&limit=20
Authorization: Bearer {{bearerToken}}


### Sort Images
# Sort options: -createdAt (newest), createdAt (oldest), -updatedAt, updatedAt
GET {{apiBaseUrl}}/images?sort=-createdAt&page=1&limit=20
Authorization: Bearer {{bearerToken}}


########################################
# Get Single Image
########################################

### Get Image by ID
# Returns full image details with populated metadata, prompt, account
GET {{apiBaseUrl}}/images/{{testImageId}}
Authorization: Bearer {{bearerToken}}


########################################
# Image Children & Related
########################################

### Get Image Children
# Get all derivative images (upscaled, edited, etc.)
GET {{apiBaseUrl}}/images/{{testImageId}}/children?page=1&limit=20
Authorization: Bearer {{bearerToken}}


########################################
# Generate Images (AI)
########################################

### Generate Image with OpenAI DALL-E (Default)
# Default model: gpt-image-1 (DALL-E 3)
# Rate limit: 30 requests per minute
# Requires credits
POST {{apiBaseUrl}}/images
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "text": "A serene mountain landscape at sunset with vibrant colors",
  "model": "gpt-image-1",
  "width": 1920,
  "height": 1080,
  "style": "realistic"
}


### Generate Image with Style Reference
# Use reference images to guide generation
POST {{apiBaseUrl}}/images
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "text": "A modern living room in the same style",
  "model": "gpt-image-1",
  "references": ["{{testImageId}}", "{{testImageId2}}"],
  "width": 1920,
  "height": 1080,
  "style": "realistic"
}


### Generate Image with KlingAI
POST {{apiBaseUrl}}/images
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "text": "A futuristic cityscape with neon lights",
  "model": "klingai-v2",
  "width": 1024,
  "height": 1024,
  "style": "realistic",
  "reference": "{{testImageId}}"
}


### Generate Image with LeonardoAI
POST {{apiBaseUrl}}/images
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "text": "A magical forest with glowing mushrooms",
  "model": "leonardoai",
  "width": 1024,
  "height": 1024,
  "style": "fantasy"
}


