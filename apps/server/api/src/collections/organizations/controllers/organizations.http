### Genfeed API - Organizations Collection Endpoints
### Manage organizations and multi-tenant functionality
### Handles: organization CRUD, accounts, members, activities, analytics

########################################
# List & Filter Organizations (Superadmin Only)
########################################

### Get All Organizations (Paginated)
# Requires superadmin role
# Default: page=1, limit=20
GET {{apiBaseUrl}}/organizations
Authorization: Bearer {{bearerToken}}


### Get Organizations with Pagination
GET {{apiBaseUrl}}/organizations?page=2&limit=10
Authorization: Bearer {{bearerToken}}


### Sort Organizations
GET {{apiBaseUrl}}/organizations?sort=-createdAt
Authorization: Bearer {{bearerToken}}


########################################
# Get Single Organization
########################################

### Get Organization by ID
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}
Authorization: Bearer {{bearerToken}}


########################################
# Organization Accounts
########################################

### Get Organization Accounts
# Get all accounts belonging to this organization
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/accounts?page=1&limit=20
Authorization: Bearer {{bearerToken}}


### Get Organization Accounts with Sort
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/accounts?sort=-createdAt
Authorization: Bearer {{bearerToken}}


########################################
# Organization Members
########################################

### Get Organization Members
# Get all members/users in this organization
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/members?page=1&limit=20
Authorization: Bearer {{bearerToken}}


### Get Organization Members with Sort
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/members?sort=createdAt
Authorization: Bearer {{bearerToken}}


########################################
# Organization Activities
########################################

### Get Organization Activities
# Get activity log for the organization
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/activities?page=1&limit=50
Authorization: Bearer {{bearerToken}}


### Get Organization Activities with Date Filter
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/activities?startDate=2025-10-01&endDate=2025-10-14
Authorization: Bearer {{bearerToken}}


########################################
# Organization Publications
########################################

### Get Organization Publications
# Get all published content from this organization
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/publications?page=1&limit=20
Authorization: Bearer {{bearerToken}}


### Filter Publications by Platform
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/publications?platform=twitter&page=1&limit=20
Authorization: Bearer {{bearerToken}}


########################################
# Organization Analytics
########################################

### Get Organization Analytics
# Get aggregated analytics for the organization
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/analytics
Authorization: Bearer {{bearerToken}}


### Get Organization Analytics with Date Range
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/analytics?startDate=2025-10-01&endDate=2025-10-14
Authorization: Bearer {{bearerToken}}


########################################
# Organization Tags
########################################

### Get Organization Tags
# Get all tags used by this organization
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/tags?page=1&limit=50
Authorization: Bearer {{bearerToken}}


### Get Organization Tags with Usage Count
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/tags?sort=-usageCount
Authorization: Bearer {{bearerToken}}


########################################
# Organization Tasks
########################################

### Get Organization Tasks
# Get all tasks for this organization
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/tasks?page=1&limit=20
Authorization: Bearer {{bearerToken}}


### Filter Tasks by Status
# Status values: pending, in_progress, completed, cancelled
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/tasks?status=pending
Authorization: Bearer {{bearerToken}}


########################################
# Organization Videos
########################################

### Get Organization Videos
# Get all videos generated by this organization
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/videos?page=1&limit=20
Authorization: Bearer {{bearerToken}}


### Filter Videos by Status
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/videos?status=completed&page=1&limit=20
Authorization: Bearer {{bearerToken}}


########################################
# Organization Ingredients
########################################

### Get Organization Ingredients
# Get all ingredients (images, videos, music) for this organization
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/ingredients?page=1&limit=20
Authorization: Bearer {{bearerToken}}


### Filter Ingredients by Category
# Category values: image, video, music, gif
GET {{apiBaseUrl}}/organizations/{{testOrganizationId}}/ingredients?category=image&page=1&limit=20
Authorization: Bearer {{bearerToken}}


########################################
# Create Organization
########################################

### Create New Organization (Superadmin Only)
POST {{apiBaseUrl}}/organizations
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "name": "Acme Corporation",
  "slug": "acme-corp",
  "plan": "pro",
  "maxAccounts": 10,
  "maxMembers": 50
}


########################################
# Update Organization
########################################

### Update Organization Details
PATCH {{apiBaseUrl}}/organizations/{{testOrganizationId}}
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "name": "Updated Organization Name",
  "description": "Updated description"
}


### Update Organization Plan
PATCH {{apiBaseUrl}}/organizations/{{testOrganizationId}}
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "plan": "enterprise",
  "maxAccounts": 50,
  "maxMembers": 200
}


########################################
# Delete Organization
########################################

### Delete Organization (Superadmin Only)
# Soft delete - marks as deleted but keeps data
DELETE {{apiBaseUrl}}/organizations/{{testOrganizationId}}
Authorization: Bearer {{bearerToken}}


########################################
# Test Cases
########################################

### Test: Invalid Organization ID Format
GET {{apiBaseUrl}}/organizations/invalid-id-format
Authorization: Bearer {{bearerToken}}


### Test: Organization Not Found
GET {{apiBaseUrl}}/organizations/507f1f77bcf86cd799439011
Authorization: Bearer {{bearerToken}}


### Test: Non-Superadmin List Organizations
# Should return 403 Forbidden
GET {{apiBaseUrl}}/organizations
Authorization: Bearer {{nonSuperadminToken}}


### Test: Create Organization Without Name
# Should return 400 Bad Request
POST {{apiBaseUrl}}/organizations
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "slug": "test-org"
}


### Test: Duplicate Organization Slug
POST {{apiBaseUrl}}/organizations
Authorization: Bearer {{bearerToken}}
Content-Type: application/json

{
  "name": "Test Org",
  "slug": "acme-corp"
}


### Test: Unauthorized Access
# Should return 401 without auth token
GET {{apiBaseUrl}}/organizations
