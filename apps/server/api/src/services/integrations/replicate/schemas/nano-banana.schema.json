{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Official Replicate API schema for google/nano-banana",
  "properties": {
    "aspect_ratio": {
      "description": "An enumeration.",
      "enum": [
        "match_input_image",
        "1:1",
        "2:3",
        "3:2",
        "3:4",
        "4:3",
        "4:5",
        "5:4",
        "9:16",
        "16:9",
        "21:9"
      ],
      "title": "aspect_ratio",
      "type": "string"
    },
    "image_input": {
      "default": [],
      "description": "Input images to transform or use as reference (supports multiple images)",
      "items": {
        "format": "uri",
        "type": "string"
      },
      "title": "Image Input",
      "type": "array",
      "x-order": 1
    },
    "output_format": {
      "description": "An enumeration.",
      "enum": ["jpg", "png"],
      "title": "output_format",
      "type": "string"
    },
    "prompt": {
      "description": "A text description of the image you want to generate",
      "title": "Prompt",
      "type": "string",
      "x-order": 0
    }
  },
  "required": ["prompt"],
  "title": "nano-banana Input Schema",
  "type": "object"
}
