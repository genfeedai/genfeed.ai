{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Official Replicate API schema for openai/gpt-image-1.5",
  "properties": {
    "aspect_ratio": {
      "description": "An enumeration.",
      "enum": ["1:1", "3:2", "2:3"],
      "title": "aspect_ratio",
      "type": "string"
    },
    "background": {
      "description": "An enumeration.",
      "enum": ["auto", "transparent", "opaque"],
      "title": "background",
      "type": "string"
    },
    "input_fidelity": {
      "description": "An enumeration.",
      "enum": ["low", "high"],
      "title": "input_fidelity",
      "type": "string"
    },
    "input_images": {
      "description": "A list of images to use as input for the generation",
      "items": {
        "anyOf": [],
        "format": "uri",
        "type": "string"
      },
      "nullable": true,
      "title": "Input Images",
      "type": "array",
      "x-order": 4
    },
    "moderation": {
      "description": "An enumeration.",
      "enum": ["auto", "low"],
      "title": "moderation",
      "type": "string"
    },
    "number_of_images": {
      "default": 1,
      "description": "Number of images to generate (1-10)",
      "maximum": 10,
      "minimum": 1,
      "title": "Number Of Images",
      "type": "integer",
      "x-order": 5
    },
    "openai_api_key": {
      "description": "Your OpenAI API key (optional - uses proxy if not provided)",
      "format": "password",
      "title": "Openai Api Key",
      "type": "string",
      "writeOnly": true,
      "x-cog-secret": true,
      "x-order": 1
    },
    "output_compression": {
      "default": 90,
      "description": "Compression level (0-100%)",
      "maximum": 100,
      "minimum": 0,
      "title": "Output Compression",
      "type": "integer",
      "x-order": 8
    },
    "output_format": {
      "description": "An enumeration.",
      "enum": ["png", "jpeg", "webp"],
      "title": "output_format",
      "type": "string"
    },
    "prompt": {
      "description": "A text description of the desired image",
      "title": "Prompt",
      "type": "string",
      "x-order": 0
    },
    "quality": {
      "description": "An enumeration.",
      "enum": ["low", "medium", "high", "auto"],
      "title": "quality",
      "type": "string"
    },
    "user_id": {
      "description": "An optional unique identifier representing your end-user. This helps OpenAI monitor and detect abuse.",
      "nullable": true,
      "title": "User Id",
      "type": "string",
      "x-order": 11
    }
  },
  "required": ["prompt"],
  "title": "gpt-image-1.5 Input Schema",
  "type": "object"
}
