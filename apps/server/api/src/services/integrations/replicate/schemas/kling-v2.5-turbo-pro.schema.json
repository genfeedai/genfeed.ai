{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Official Replicate API schema for kwaivgi/kling-v2.5-turbo-pro",
  "properties": {
    "aspect_ratio": {
      "description": "An enumeration.",
      "enum": ["16:9", "9:16", "1:1"],
      "title": "aspect_ratio",
      "type": "string"
    },
    "duration": {
      "description": "An enumeration.",
      "enum": [5, 10],
      "title": "duration",
      "type": "integer"
    },
    "image": {
      "deprecated": true,
      "description": "Deprecated: Use start_image instead.",
      "format": "uri",
      "nullable": true,
      "title": "Image",
      "type": "string"
    },
    "negative_prompt": {
      "default": "",
      "description": "Things you do not want to see in the video",
      "title": "Negative Prompt",
      "type": "string"
    },
    "prompt": {
      "description": "Text prompt for video generation",
      "title": "Prompt",
      "type": "string"
    },
    "start_image": {
      "description": "First frame of the video",
      "format": "uri",
      "title": "Start Image",
      "type": "string"
    }
  },
  "required": ["prompt"],
  "title": "kling-v2.5-turbo-pro Input Schema",
  "type": "object"
}
