{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Official Replicate API schema for Google Veo 3.1 Fast",
  "properties": {
    "aspect_ratio": {
      "allOf": [
        {
          "$ref": "#/components/schemas/aspect_ratio"
        }
      ],
      "default": "16:9",
      "description": "Video aspect ratio",
      "x-order": 1
    },
    "duration": {
      "allOf": [
        {
          "$ref": "#/components/schemas/duration"
        }
      ],
      "default": 8,
      "description": "Video duration in seconds",
      "x-order": 2
    },
    "generate_audio": {
      "default": true,
      "description": "Generate audio with the video",
      "title": "Generate Audio",
      "type": "boolean",
      "x-order": 7
    },
    "image": {
      "description": "Input image to start generating from. Ideal images are 16:9 or 9:16 and 1280x720 or 720x1280, depending on the aspect ratio you choose.",
      "format": "uri",
      "nullable": true,
      "title": "Image",
      "type": "string",
      "x-order": 3
    },
    "last_frame": {
      "description": "Ending image for interpolation. When provided with an input image, creates a transition between the two images.",
      "format": "uri",
      "nullable": true,
      "title": "Last Frame",
      "type": "string",
      "x-order": 4
    },
    "negative_prompt": {
      "description": "Description of what to exclude from the generated video",
      "nullable": true,
      "title": "Negative Prompt",
      "type": "string",
      "x-order": 5
    },
    "prompt": {
      "description": "Text prompt for video generation",
      "title": "Prompt",
      "type": "string",
      "x-order": 0
    },
    "resolution": {
      "allOf": [
        {
          "$ref": "#/components/schemas/resolution"
        }
      ],
      "default": "1080p",
      "description": "Resolution of the generated video",
      "x-order": 6
    },
    "seed": {
      "description": "Random seed. Omit for random generations",
      "nullable": true,
      "title": "Seed",
      "type": "integer",
      "x-order": 8
    }
  },
  "required": ["prompt"],
  "title": "Google Veo 3.1 Fast Input Schema",
  "type": "object"
}
