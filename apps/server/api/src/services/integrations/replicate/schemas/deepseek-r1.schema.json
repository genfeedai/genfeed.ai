{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "description": "Official Replicate API schema for deepseek-ai/deepseek-r1",
  "properties": {
    "frequency_penalty": {
      "default": 0,
      "description": "Frequency penalty",
      "title": "Frequency Penalty",
      "type": "number",
      "x-order": 4
    },
    "max_tokens": {
      "default": 2048,
      "description": "The maximum number of tokens the model should generate as output.",
      "title": "Max Tokens",
      "type": "integer",
      "x-order": 1
    },
    "presence_penalty": {
      "default": 0,
      "description": "Presence penalty",
      "title": "Presence Penalty",
      "type": "number",
      "x-order": 3
    },
    "prompt": {
      "default": "",
      "description": "Prompt",
      "title": "Prompt",
      "type": "string",
      "x-order": 0
    },
    "temperature": {
      "default": 0.1,
      "description": "The value used to modulate the next token probabilities.",
      "title": "Temperature",
      "type": "number",
      "x-order": 2
    },
    "top_p": {
      "default": 1,
      "description": "Top-p (nucleus) sampling",
      "title": "Top P",
      "type": "number",
      "x-order": 5
    }
  },
  "title": "deepseek-r1 Input Schema",
  "type": "object"
}
