{
  "dependencies": {
    "@anthropic-ai/sdk": "0.82.0",
    "@aws-sdk/client-cloudfront": "3.1024.0",
    "@aws-sdk/client-ec2": "3.1024.0",
    "@genfeedai/config": "workspace:*",
    "@genfeedai/integrations": "workspace:*",
    "@genfeedai/serializers": "workspace:*",
    "@genfeedai/types": "workspace:*",
    "@genfeedai/workflow-engine": "workspace:*",
    "@genfeedai/workflow-saas": "workspace:*",
    "@genfeedai/constants": "workspace:*",
    "@genfeedai/enums": "workspace:*",
    "@genfeedai/helpers": "workspace:*",
    "@genfeedai/interfaces": "workspace:*",
    "@genfeedai/tools": "workspace:*",
    "@nestjs/event-emitter": "3.0.1",
    "effect": "^3.21.0",
    "openai": "6.33.0",
    "rss": "1.2.2"
  },
  "description": "Genfeed API Service",
  "devDependencies": {
    "@types/rss": "0.0.32",
    "mongodb": "7.1.1",
    "unplugin-swc": "1.4.2"
  },
  "main": "../dist/apps/api/main.js",
  "name": "@genfeedai/api",
  "private": true,
  "scripts": {
    "build": "cd .. && nest build api",
    "build:prod": "cd .. && nest build api && cd api && (bun run sentry:sourcemaps || true)",
    "db:check-orphans": "bun run scripts/mongodb/check-orphans.ts",
    "db:cleanup-broken-knowledge-bases": "bun run scripts/mongodb/cleanup-broken-knowledge-bases.ts",
    "db:cleanup-orphaned-user-cluster": "bun run scripts/mongodb/cleanup-orphaned-user-cluster.ts",
    "db:collection-normalization-audit": "bun run ../../scripts/migrations/collection-normalization-audit.ts",
    "db:fix-agent-collections": "bun run scripts/mongodb/fix-agent-collections.ts",
    "db:normalize-agent-objectids": "bun run scripts/mongodb/normalize-agent-objectids.ts",
    "db:normalize-collections": "bun run ../../scripts/migrations/normalize-mongo-collection-names.ts",
    "db:normalize-enabled-models": "bun run scripts/mongodb/normalize-enabled-models.ts",
    "db:remove-tasks": "bun run scripts/mongodb/remove-tasks.ts",
    "db:repair-catalog-voice-ownership": "bun run scripts/mongodb/repair-catalog-voice-ownership.ts",
    "db:repair-post-credentials": "bun run scripts/mongodb/repair-post-credentials.ts",
    "deps:update": "bunx npm-check-updates -u --reject typescript && bun install",
    "dev": "cd .. && NODE_OPTIONS=\"--max-old-space-size=4096 --expose-gc\" nest start api --watch",
    "dev:webpack": "cd .. && NODE_OPTIONS=\"--max-old-space-size=4096 --expose-gc\" nest start api --watch",
    "lint": "bun run scripts/check-request-context-usage.ts && biome lint --write src",
    "seed:demo": "bun run scripts/seeds/demo.seed.ts",
    "seed:demo:dry": "bun run scripts/seeds/demo.seed.ts --dry-run",
    "seed:marketplace": "bun run scripts/seeds/marketplace.seed.ts",
    "seed:marketplace:dry": "bun run scripts/seeds/marketplace.seed.ts --dry-run",
    "seed:models": "bun run scripts/seeds/models.seed.ts",
    "seed:models:dry": "bun run scripts/seeds/models.seed.ts --dry-run",
    "seed:workflows": "bun run scripts/seeds/workflows.seed.ts",
    "seed:workflows:dry": "bun run scripts/seeds/workflows.seed.ts --dry-run",
    "sentry:inject": "sentry-cli sourcemaps inject --org genfeedai --project api-genfeed-ai ../dist",
    "sentry:sourcemaps": "[ -z \"$SENTRY_AUTH_TOKEN\" ] && echo 'Sentry upload skipped (no token)' || (bun run sentry:inject && bun run sentry:upload)",
    "sentry:upload": "sentry-cli sourcemaps upload --org genfeedai --project api-genfeed-ai ../dist",
    "start": "cd .. && nest start api",
    "start:debug": "cd .. && nest start api --debug --watch",
    "start:dev": "cd .. && NODE_OPTIONS=\"--max-old-space-size=4096 --expose-gc\" nest start api --watch",
    "start:prod": "node --max-old-space-size=8192 --expose-gc -r tsconfig-paths/register ../dist/apps/api/main",
    "test": "vitest run --config vitest.config.ts",
    "test:cov": "vitest run --coverage --config vitest.config.ts",
    "test:e2e": "vitest run --config vitest.config.e2e.ts",
    "test:e2e:ci": "vitest run --config vitest.config.e2e.ts test/e2e/integrations.e2e-spec.ts test/integration/payment-processing.integration.spec.ts test/integration/health.e2e-spec.spec.ts",
    "test:e2e:cov": "vitest run --coverage --config vitest.config.e2e.ts",
    "test:file": "vitest run --config vitest.config.ts",
    "test:file:cov": "vitest run --coverage --config vitest.config.ts",
    "test:watch": "vitest watch --config vitest.config.ts"
  },
  "version": "1.0.0"
}
