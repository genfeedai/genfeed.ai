# ============================================
# FILES APP - ENVIRONMENT EXAMPLE
# ============================================
# Copy this file to .env.local and fill in your actual values.
# Shared base config goes in .env (non-secret, same across environments).
# Never commit .env.local or .env.production to version control.
#
# Loading priority: .env.local > .env > root .env.local > root .env
# ============================================

# ===== SHARED BASE (.env) =====
# These go in .env - same value across all environments

# --------------------------------------------
# Server Configuration
# --------------------------------------------
SERVICE_NAME=files-genfeed-ai

# --------------------------------------------
# FFmpeg Configuration
# --------------------------------------------
TEMP_DIR=/tmp
FFMPEG_THREADS=2
FFMPEG_PATH=/usr/bin/ffmpeg
FFMPEG_VIDEO_CODEC=libx264
FFMPEG_AUDIO_CODEC=aac
FFMPEG_CRF=23
FFMPEG_PRESET=medium
FFMPEG_PIXEL_FORMAT=yuv420p
FFMPEG_TIMEOUT=600000
FFMPEG_MAX_PROCESSES=4
FFMPEG_TEMP_DIR=/tmp/ffmpeg

# --------------------------------------------
# Sentry
# --------------------------------------------
SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN_FILES=your_sentry_auth_token

# ===== LOCAL OVERRIDES (.env.local) =====
# These go in .env.local - values specific to local development

# --------------------------------------------
# Server
# --------------------------------------------
PORT=3005

# --------------------------------------------
# Redis
# --------------------------------------------
REDIS_URL=redis://localhost:6379

# --------------------------------------------
# AWS
# --------------------------------------------
AWS_REGION=us-west-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_IMAGE_COMPRESSION=50

# --------------------------------------------
# WebSocket Configuration
# --------------------------------------------
WEBSOCKET_URL=ws://local.genfeed.ai:3001

# --------------------------------------------
# Genfeed API & CDN
# --------------------------------------------
GENFEEDAI_API_URL=http://local.genfeed.ai:3001
GENFEEDAI_CDN_URL=https://staging-cdn.genfeed.ai

# --------------------------------------------
# Clerk Authentication
# --------------------------------------------
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# --------------------------------------------
# Sentry
# --------------------------------------------
SENTRY_ENVIRONMENT=development
