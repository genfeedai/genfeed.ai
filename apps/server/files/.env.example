# ============================================
# FILES APP - GENERATED OUTPUT REFERENCE
# ============================================
# Canonical source of truth: `../../../.env.local|.env.staging|.env.production`
# Generate this file with `bun run env:sync <local|staging|production>`.
# Keep real values in the root env files, not here.
# ============================================

# ===== SHARED BASE (.env) =====
# These go in .env - same value across all environments

# --------------------------------------------
# Server Configuration
# --------------------------------------------
SERVICE_NAME=files-genfeed-ai

# --------------------------------------------
# FFmpeg Configuration
# --------------------------------------------
TEMP_DIR=/tmp
FFMPEG_THREADS=2
FFMPEG_PATH=/usr/bin/ffmpeg
FFMPEG_VIDEO_CODEC=libx264
FFMPEG_AUDIO_CODEC=aac
FFMPEG_CRF=23
FFMPEG_PRESET=medium
FFMPEG_PIXEL_FORMAT=yuv420p
FFMPEG_TIMEOUT=600000
FFMPEG_MAX_PROCESSES=4
FFMPEG_TEMP_DIR=/tmp/ffmpeg

# --------------------------------------------
# Sentry
# --------------------------------------------
SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ===== LOCAL OVERRIDES (.env.local) =====
# These go in .env.local - values specific to local development

# --------------------------------------------
# Server
# --------------------------------------------
PORT=3005

# --------------------------------------------
# AWS
# --------------------------------------------
AWS_REGION=us-west-1
AWS_S3_BUCKET=your-s3-bucket-name
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_IMAGE_COMPRESSION=50

# --------------------------------------------
# WebSocket Configuration
# --------------------------------------------
WEBSOCKET_URL=ws://local.genfeed.ai:3001

# --------------------------------------------
# Genfeed CDN
# --------------------------------------------
GENFEEDAI_CDN_URL=https://staging-cdn.genfeed.ai
