{
  "compilerOptions": {
    "rootDir": "../../..",
    "declaration": false,
    "declarationMap": false,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "outDir": "../dist/apps/videos",
    "paths": {
      "@libs/*": ["../../../packages/libs/*"],
      "@videos/*": ["./src/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.e2e-spec.ts"
  ],
  "extends": "../tsconfig.json",
  "include": ["src/**/*"]
}
