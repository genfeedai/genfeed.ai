# ============================================
# NOTIFICATIONS APP - GENERATED OUTPUT REFERENCE
# ============================================
# Canonical source of truth: `../../../.env.local|.env.staging|.env.production`
# Generate this file with `bun run env:sync <local|staging|production>`.
# Keep real values in the root env files, not here.
# ============================================

# ===== SHARED BASE (.env) =====
# These go in .env - same value across all environments

# --------------------------------------------
# Server Configuration
# --------------------------------------------
SERVICE_NAME=notifications
VERSION=1.0.0

# --------------------------------------------
# Sentry
# --------------------------------------------
SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ===== LOCAL OVERRIDES (.env.local) =====
# These go in .env.local - values specific to local development

# --------------------------------------------
# Server
# --------------------------------------------
PORT=3007

# --------------------------------------------
# API Communication
# --------------------------------------------
API_BASE_URL=http://local.genfeed.ai:3001
API_SECRET_KEY=
GENFEED_API_KEY=

# --------------------------------------------
# Telegram Configuration
# --------------------------------------------
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_BOT_USERNAME=
TELEGRAM_ADMIN_IDS=

# --------------------------------------------
# Discord Configuration
# --------------------------------------------
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_GUILD_ID=your_discord_guild_id
DISCORD_CHANNEL_ID_POSTS=your_channel_id
DISCORD_CHANNEL_ID_STUDIO=your_channel_id
DISCORD_CHANNEL_ID_USERS=your_channel_id

# --------------------------------------------
# Resend Configuration
# --------------------------------------------
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Genfeed <updates@genfeed.ai>
RESEND_REPLY_TO_EMAIL=support@genfeed.ai

# --------------------------------------------
# Twitch Configuration
# --------------------------------------------
TWITCH_CLIENT_ID=test
