# ============================================
# BACKEND SERVICES — SHARED ENVIRONMENT
# ============================================
# Vars shared by all backend services (api, files, mcp, notifications, workers, etc.)
# BaseConfigService loads: root .env → root .env.local → {service}/.env → {service}/.env.local
# Service-specific overrides go in each service's own .env / .env.local files.
# ============================================

# ===== ROOT .env.local =====

# Redis (all services)
REDIS_URL=redis://localhost:6379

# Clerk Authentication (all services)
CLERK_SECRET_KEY=sk_test_xxxxx

# Genfeed API URL (all services)
GENFEEDAI_API_URL=http://local.genfeed.ai:3001

# MongoDB (api, workers)
MONGODB_URI=mongodb://localhost:27017/genfeed

# Sentry (all services — optional for local dev)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
