# ============================================
# BACKEND SERVICES — GENERATED OUTPUT REFERENCE
# ============================================
# Canonical source of truth: `../../.env.local|.env.staging|.env.production`
# Generate service env files with `bun run env:sync <local|staging|production>`.
# This file documents the shared backend surface only; do not store secrets here.
# ============================================

# ===== ROOT .env.local =====

# Redis (all services)
REDIS_URL=redis://localhost:6379

# Clerk Authentication (all services)
CLERK_SECRET_KEY=sk_test_xxxxx

# Genfeed API URL (all services)
GENFEEDAI_API_URL=http://local.genfeed.ai:3001

# MongoDB (api, workers)
MONGODB_URI=mongodb://localhost:27017/genfeed

# Sentry (all services — optional for local dev)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
