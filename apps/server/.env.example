# ============================================
# BACKEND SERVICES — GENERATED OUTPUT REFERENCE
# ============================================
# Canonical source of truth: `../../.env.local|.env.staging|.env.production`
# Generate service env files with `bun run env:sync <local|staging|production>`.
# This file documents the shared backend surface only; do not store secrets here.
# ============================================

# ===== ROOT .env.local =====

# Redis (all services)
REDIS_URL=redis://localhost:6379

# Better Auth Authentication (all services)
BETTER_AUTH_ENABLED=true
BETTER_AUTH_SECRET=replace_with_a_long_random_secret
BETTER_AUTH_URL=http://genfeed.localhost:3010
BETTER_AUTH_TRUSTED_ORIGINS=http://genfeed.localhost:3000,http://genfeed.localhost:3002

# Genfeed API URL (all services)
GENFEEDAI_API_URL=http://genfeed.localhost:3010

# PostgreSQL / Prisma (api, workers)
DATABASE_URL=postgresql://user:pass@localhost:5432/genfeed

# Sentry (all services — optional for local dev)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
