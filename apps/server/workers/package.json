{
  "dependencies": {
    "@aws-sdk/client-ec2": "3.1079.0",
    "@genfeedai/config": "workspace:*",
    "@genfeedai/constants": "workspace:*",
    "@genfeedai/enums": "workspace:*",
    "@genfeedai/helpers": "workspace:*",
    "@genfeedai/interfaces": "workspace:*",
    "@genfeedai/prisma": "workspace:*",
    "@genfeedai/queue-contracts": "workspace:*",
    "@genfeedai/server": "workspace:*",
    "@genfeedai/workflows": "workspace:*",
    "@nestjs/event-emitter": "3.1.0"
  },
  "description": "Genfeed Workers Service (Cron Jobs)",
  "devDependencies": {
    "@nestjs/testing": "11.1.27",
    "@types/multer": "2.2.0",
    "unplugin-swc": "1.5.9"
  },
  "main": "../dist/apps/workers/main.js",
  "name": "@genfeedai/workers",
  "private": true,
  "scripts": {
    "build": "cd .. && nest build workers",
    "build:prod": "cd .. && nest build workers && cd workers && if [ -n \"$SENTRY_AUTH_TOKEN\" ]; then bun run sentry:sourcemaps || true; fi",
    "deps:update": "bunx npm-check-updates -u --reject typescript && bun install",
    "dev": "cd .. && NODE_OPTIONS=\"--max-old-space-size=4096 --expose-gc\" nest start workers --watch",
    "dev:webpack": "cd .. && NODE_OPTIONS=\"--max-old-space-size=4096 --expose-gc\" nest start workers --watch",
    "lint": "biome lint --write src --no-errors-on-unmatched",
    "sentry:inject": "sentry-cli sourcemaps inject --org genfeedai --project workers-genfeed-ai ../dist",
    "sentry:sourcemaps": "[ -z \"$SENTRY_AUTH_TOKEN\" ] && echo 'Sentry upload skipped (no token)' || (bun run sentry:inject && bun run sentry:upload)",
    "sentry:upload": "sentry-cli sourcemaps upload --org genfeedai --project workers-genfeed-ai ../dist",
    "start": "cd .. && nest start workers",
    "start:debug": "cd .. && nest start workers --debug --watch",
    "start:dev": "cd .. && NODE_OPTIONS=\"--max-old-space-size=4096 --expose-gc\" nest start workers --watch",
    "start:prod": "node -r tsconfig-paths/register --max-old-space-size=8192 --expose-gc ../dist/apps/workers/main",
    "test": "vitest run --config vitest.config.ts",
    "test:cov": "vitest run --config vitest.config.ts --coverage",
    "test:cron": "vitest run --config vitest.cron.config.ts",
    "test:cron:watch": "vitest --config vitest.cron.config.ts",
    "test:e2e": "echo 'No e2e tests yet'",
    "test:watch": "vitest --config vitest.config.ts",
    "type-check": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "version": "1.0.0",
  "type": "module"
}
