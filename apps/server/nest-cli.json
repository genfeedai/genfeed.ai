{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "compilerOptions": {
    "deleteOutDir": true,
    "typeCheck": false,
    "webpack": true
  },
  "monorepo": true,
  "projects": {
    "api": {
      "compilerOptions": {
        "assets": [
          {
            "exclude": "**/tsconfig*.json",
            "include": "config/**/*.json",
            "outDir": "dist/server/api/src",
            "watchAssets": true
          },
          {
            "include": "src/services/integrations/replicate/schemas/**/*.json",
            "outDir": "dist/apps/api/services/integrations/replicate/schemas",
            "watchAssets": true
          }
        ],
        "tsConfigPath": "api/tsconfig.app.json",
        "webpackConfigPath": "api/webpack.config.js"
      },
      "entryFile": "main",
      "root": "api",
      "sourceRoot": "api/src",
      "type": "application"
    },
    "clips": {
      "compilerOptions": {
        "tsConfigPath": "clips/tsconfig.app.json",
        "webpackConfigPath": "clips/webpack.config.js"
      },
      "entryFile": "main",
      "root": "clips",
      "sourceRoot": "clips/src",
      "type": "application"
    },
    "discord": {
      "compilerOptions": {
        "tsConfigPath": "discord/tsconfig.app.json",
        "webpackConfigPath": "discord/webpack.config.js"
      },
      "entryFile": "main",
