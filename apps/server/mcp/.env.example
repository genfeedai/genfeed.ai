# ============================================
# MCP APP - GENERATED OUTPUT REFERENCE
# ============================================
# Canonical source of truth: `../../../.env.local|.env.staging|.env.production`
# Generate this file with `bun run env:sync <local|staging|production>`.
# Keep real values in the root env files, not here.
# ============================================

# ===== SHARED BASE (.env) =====
# These go in .env - same value across all environments

# --------------------------------------------
# Server Configuration
# --------------------------------------------
SERVICE_NAME=mcp
VERSION=1.0.0

# --------------------------------------------
# MCP-Specific Configuration
# --------------------------------------------
GENFEED_API_KEY=

# --------------------------------------------
# Sentry
# --------------------------------------------
SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# ===== LOCAL OVERRIDES (.env.local) =====
# These go in .env.local - values specific to local development

# --------------------------------------------
# Server
# --------------------------------------------
PORT=3006
