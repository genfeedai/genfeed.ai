# ============================================
# MCP APP - ENVIRONMENT EXAMPLE
# ============================================
# Copy this file to .env.local and fill in your actual values.
# Shared base config goes in .env (non-secret, same across environments).
# Never commit .env.local or .env.production to version control.
#
# Loading priority: .env.local > .env > root .env.local > root .env
# ============================================

# ===== SHARED BASE (.env) =====
# These go in .env - same value across all environments

# --------------------------------------------
# Server Configuration
# --------------------------------------------
SERVICE_NAME=mcp
VERSION=1.0.0

# --------------------------------------------
# MCP-Specific Configuration
# --------------------------------------------
GENFEED_API_KEY=

# --------------------------------------------
# Sentry
# --------------------------------------------
SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN_MCP=your_sentry_auth_token

# ===== LOCAL OVERRIDES (.env.local) =====
# These go in .env.local - values specific to local development

# --------------------------------------------
# Server
# --------------------------------------------
PORT=3006

# --------------------------------------------
# Redis
# --------------------------------------------
REDIS_URL=redis://localhost:6379

# --------------------------------------------
# Genfeed API Configuration
# --------------------------------------------
GENFEEDAI_API_URL=http://local.genfeed.ai:3001

# --------------------------------------------
# Clerk Authentication
# --------------------------------------------
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key

# --------------------------------------------
# Sentry
# --------------------------------------------
SENTRY_ENVIRONMENT=development
