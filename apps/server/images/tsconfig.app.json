{
  "compilerOptions": {
    "rootDir": "../../..",
    "declaration": false,
    "declarationMap": false,
    "outDir": "../dist/apps/images",
    "paths": {
      "@genfeedai/types": ["../../../packages/types/src/index.ts"],
      "@genfeedai/types/*": ["../../../packages/types/src/*"],
      "@genfeedai/workflows": ["../../../packages/workflows/src/index.ts"],
      "@genfeedai/workflows/*": ["../../../packages/workflows/src/*"],
      "@images/*": ["./src/*"],
      "@libs/*": ["../../../packages/libs/*"]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "**/*.spec.ts",
    "**/*.test.ts",
    "**/*.e2e-spec.ts"
  ],
  "extends": "../tsconfig.json",
  "include": ["src/**/*"]
}
