{
  "compilerOptions": {
    "rootDir": "../../..",
    "declaration": false,
    "declarationMap": false,
    "outDir": "../dist/apps/clips",
    "paths": {
      "@clips/*": ["./src/*"],
      "@libs/*": ["../../../packages/libs/*"]
    }
  },
  "exclude": [
