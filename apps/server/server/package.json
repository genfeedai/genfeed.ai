{
  "dependencies": {
    "@genfeedai/enums": "workspace:*",
    "@genfeedai/helpers": "workspace:*",
    "@genfeedai/integrations": "workspace:*",
    "@genfeedai/interfaces": "workspace:*",
    "@genfeedai/prisma": "workspace:*",
    "@genfeedai/queue-contracts": "workspace:*",
    "@genfeedai/serializers": "workspace:*",
    "@nestjs/axios": "4.0.1",
    "@nestjs/bullmq": "11.0.4",
    "@nestjs/common": "11.1.28",
    "bullmq": "5.79.3",
    "jsonwebtoken": "9.0.3",
    "rxjs": "7.8.2"
  },
  "description": "Server-tier services shared by Genfeed API and workers",
  "devDependencies": {
    "@nestjs/testing": "11.1.28",
    "@types/jsonwebtoken": "9.0.10",
    "@types/node": "26.1.1",
    "typescript": "6.0.2",
    "vitest": "4.1.10"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./*": {
      "types": "./src/*.ts",
      "default": "./src/*.ts"
    }
  },
  "files": [
    "src"
  ],
  "main": "./src/index.ts",
  "name": "@genfeedai/server",
  "private": true,
  "scripts": {
    "build": "echo 'Source-level package \u2014 consumed via path aliases, no build needed'",
    "clean": "echo 'Nothing to clean'",
    "type-check": "bunx tsc --noEmit -p tsconfig.typecheck.json"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./src/index.ts",
  "version": "0.1.0"
}
