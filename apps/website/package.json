{
  "dependencies": {
    "@genfeedai/constants": "*",
    "@genfeedai/helpers": "*",
    "@genfeedai/interfaces": "*",
    "@genfeedai/next-config": "*",
    "@genfeedai/types": "*",
    "@tiptap/core": "3.22.4",
    "@tiptap/extension-image": "3.22.4",
    "@tiptap/extension-link": "3.22.4",
    "@tiptap/extension-placeholder": "3.22.4",
    "@tiptap/extensions": "3.22.4",
    "@tiptap/pm": "3.22.4",
    "@tiptap/react": "3.22.4",
    "@tiptap/starter-kit": "3.22.4",
    "clsx": "2.1.1",
    "gsap": "3.15.0",
    "lucide-react": "1.9.0",
    "next": "16.2.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "tailwind-merge": "3.5.0"
  },
  "description": "Genfeed Website - Marketing site with landing pages, documentation, and public-facing content",
  "name": "@genfeedai/website",
  "private": true,
  "scripts": {
    "analyze": "ANALYZE=true next build",
    "analyze:browser": "ANALYZE=true BUNDLE_ANALYZE=browser next build",
    "analyze:server": "ANALYZE=true BUNDLE_ANALYZE=server next build",
    "build": "next build",
    "deps:update": "bunx npm-check-updates -u --reject typescript && bun install",
    "dev": "NODE_OPTIONS='--max-old-space-size=4096 --disable-warning=DEP0169' next dev --turbopack",
    "generate:llms": "bun run scripts/generate-llms-txt.ts",
    "lint": "biome check app src packages scripts instrumentation.ts instrumentation-client.ts next.config.ts postcss.config.mjs tailwind.config.ts package.json tsconfig.json vercel.json sentry.edge.config.ts sentry.server.config.ts README.md",
    "prebuild": "bun run scripts/generate-llms-txt.ts",
    "start": "next start",
    "test": "vitest run --config ../vitest.config.mts",
    "test:cov": "vitest run --coverage --config ../vitest.config.mts",
    "test:watch": "vitest --config ../vitest.config.mts",
    "type-check": "tsc --noEmit"
  },
  "version": "1.0.0",
  "devDependencies": {
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.2"
  }
}
