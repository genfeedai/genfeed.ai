{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "alias": ["genfeed.ai", "www.genfeed.ai"],
  "buildCommand": "bunx next build",
  "git": {
    "deploymentEnabled": {
      "*": false,
      "master": true,
      "staging": true
    }
  },
  "installCommand": "cd ../../ && sh scripts/sh/vercel-bun.sh install --ignore-scripts",
  "outputDirectory": ".next"
}
