# Local development endpoints
NEXT_PUBLIC_API_ENDPOINT=http://local.genfeed.ai:3001/v1
NEXT_PUBLIC_WS_ENDPOINT=http://local.genfeed.ai:3007

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key

# Website assets
NEXT_PUBLIC_ASSETS_ENDPOINT=https://assets.genfeed.ai

# Sentry
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# OAuth
MEDIUM_REDIRECT_URI=http://local.genfeed.ai:3102/auth/medium/callback

# App endpoints (must be in each Next.js app's .env.local for monorepo)
NEXT_PUBLIC_APPS_APP_ENDPOINT=http://local.genfeed.ai:3102
NEXT_PUBLIC_APPS_ADMIN_ENDPOINT=http://local.genfeed.ai:3101
NEXT_PUBLIC_APPS_MARKETPLACE_ENDPOINT=http://local.genfeed.ai:3104
NEXT_PUBLIC_APPS_WEBSITE_ENDPOINT=http://local.genfeed.ai:3105

# CDN
NEXT_PUBLIC_CDN_URL=https://staging-cdn.genfeed.ai
