# Generated output reference for `apps/website`.
# Canonical source of truth: `../../.env.local|.env.staging|.env.production`
# Regenerate with `bun run env:sync <local|staging|production>`.
# Do not maintain secrets here manually.

# Port (Next.js reads PORT env var automatically)
PORT=3002

# Local development endpoints
NEXT_PUBLIC_API_ENDPOINT=http://local.genfeed.ai:3010/v1
NEXT_PUBLIC_WS_ENDPOINT=http://local.genfeed.ai:3011

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key
CLERK_SECRET_KEY=sk_test_your_secret_key

# Website assets
NEXT_PUBLIC_ASSETS_ENDPOINT=https://assets.genfeed.ai

# Sentry
NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn
SENTRY_AUTH_TOKEN=your_sentry_auth_token

# App endpoints (must be in each Next.js app's .env.local for monorepo)
NEXT_PUBLIC_APPS_APP_ENDPOINT=http://local.genfeed.ai:3000
NEXT_PUBLIC_APPS_MARKETPLACE_ENDPOINT=http://local.genfeed.ai:3003
NEXT_PUBLIC_APPS_WEBSITE_ENDPOINT=http://local.genfeed.ai:3002

# CDN
NEXT_PUBLIC_CDN_URL=https://staging-cdn.genfeed.ai
