{
  "name": "genfeed.ai",
  "description": "The open source AI OS for content creation",
  "private": true,
  "license": "AGPL-3.0",
  "homepage": "https://genfeed.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/genfeedai/genfeed.ai.git"
  },
  "bugs": {
    "url": "https://github.com/genfeedai/genfeed.ai/issues"
  },
  "keywords": [
    "ai",
    "content-creation",
    "workflow",
    "video-generation",
    "image-generation",
    "publishing",
    "self-hosted",
    "open-source"
  ],
  "workspaces": [
    "apps/server/*",
    "apps/app",
    "apps/docs",
    "apps/website",
    "apps/desktop/app",
    "apps/mobile/app",
    "apps/extensions/browser/app",
    "apps/extensions/ide/app",
    "packages/*",
    "ee/packages/*"
  ],
  "packageManager": "bun@1.3.14",
  "engines": {
    "node": ">=24 <25"
  },
  "scripts": {
    "analyze:claude-patterns": "bun run scripts/daily-pattern-miner.ts",
    "analyze:claude-patterns:daily": "bun run scripts/analyze-claude-sessions.ts -- --previous-day --out docs/claude-session-analysis-daily.md --json-out docs/claude-session-analysis-daily.json && bun run scripts/daily-pattern-miner.ts -- --input docs/claude-session-analysis-daily.json --out docs/claude-pattern-miner-report.md",
    "analyze:claude-sessions": "bun run scripts/analyze-claude-sessions.ts",
    "audit:api": "bun run audit:api:endpoints && bun run audit:api:sql",
    "audit:api:endpoints": "bun run scripts/api-audit/endpoint-inventory.ts",
    "audit:api:smoke": "bun run scripts/api-audit/openapi-smoke.ts",
    "audit:api:sql": "bun run scripts/api-audit/sql-risk-audit.ts",
    "audit:api:sql:ci": "bun run scripts/api-audit/sql-risk-audit.ts --fail-on-high",
    "postinstall": "scripts/setup-skills.sh",
    "setup:skills": "scripts/setup-skills.sh",
    "setup:skills:sync": "scripts/setup-skills.sh --sync",
    "check:skills": "scripts/setup-skills.sh --check",
    "check:skills-readme": "bun run scripts/check-skills-readme-drift.ts",
    "posthog:funnel-alerts": "bun run scripts/posthog/setup-funnel-alerts.ts",
    "build": "bunx turbo run build --filter='./packages/*'",
    "build:app": "bunx turbo run build --filter=@genfeedai/app",
    "build:backend:parallel": "bunx turbo run build --filter='./apps/server/*'",
    "build:backend:sequential": "bunx turbo run build --filter='./apps/server/*' --concurrency=1",
    "build:cli": "bunx turbo run build --filter=@genfeedai/cli",
    "build:desktop": "bunx turbo run build --filter=@genfeedai/desktop",
    "build:docs": "bunx turbo run build --filter=@genfeedai/docs",
    "build:packages": "bunx turbo run build --filter='./packages/*'",
    "build:web:parallel": "bunx turbo run build --filter=@genfeedai/app --filter=@genfeedai/website --filter=@genfeedai/docs",
    "build:web:sequential": "bunx turbo run build --filter=@genfeedai/app --filter=@genfeedai/website --filter=@genfeedai/docs --concurrency=1",
    "build:website": "bunx turbo run build --filter=@genfeedai/website",
    "check:architecture": "bun run scripts/check-architecture.ts",
    "check:cron-boundary": "bun run scripts/architecture/check-platform-cron-boundary.ts",
    "check:di-value-imports": "bun run scripts/check-di-value-imports.ts",
    "check:import-cycles": "bun run scripts/check-import-cycles.ts",
    "check:mcp-parity": "bun run --filter=@genfeedai/api mcp:parity",
    "check:ui-guards": "bun run scripts/ui/check-ui-guards.ts",
    "publish:package": "./scripts/publish-package.sh",
    "check:multi-tenancy": "bun run scripts/check-multi-tenancy.ts",
    "check:nested-node-modules": "bun run scripts/check-nested-node-modules.ts",
    "check:pages-boundary": "bun run scripts/check-pages-boundary.ts",
    "check:package-api-surface": "bun run scripts/check-package-api-surface.ts",
    "check:design-system": "bun run scripts/check-design-system.ts",
    "check:desktop-schema-drift": "bun run scripts/check-desktop-schema-drift.ts",
    "check:generated-source": "bun run scripts/check-generated-source-artifacts.ts",
    "check:serializer-drift": "bun run scripts/check-serializer-drift.ts",
    "clean": "bunx turbo clean && rm -rf node_modules",
    "clean:generated-source": "bun run scripts/check-generated-source-artifacts.ts --fix",
    "dead-code": "bunx knip --reporter compact",
    "deploy:production": "gh workflow run deploy-ecs.yml --ref master",
    "deploy:production:rollback": "bash -lc 'test -n \"$IMAGE_TAG\" || { echo \"Set IMAGE_TAG=<sha> for rollback\" >&2; exit 1; }; gh workflow run deploy-ecs.yml --ref master -f image_tag=\"$IMAGE_TAG\" -f allow_rollback=true'",
    "deps:update": "bunx npm-check-updates -u --deep --cooldown 3h --reject typescript && bun install",
    "dev": "bunx turbo run dev",
    "dev:admin:be": "bunx turbo run dev --filter=@genfeedai/api --filter=@genfeedai/notifications",
    "dev:all": "bunx turbo run dev",
    "dev:app": "bunx turbo run dev --filter=@genfeedai/app",
    "dev:app:be": "bunx turbo run dev --filter=@genfeedai/api --filter=@genfeedai/notifications",
    "dev:app:fe": "bunx turbo run dev --filter=@genfeedai/app",
    "dev:backend": "bunx turbo run dev --filter=@genfeedai/api --filter=@genfeedai/files --filter=@genfeedai/mcp --filter=@genfeedai/notifications --filter=@genfeedai/workers --concurrency=6",
    "dev:cli": "bun run --cwd packages/cli dev --",
    "dev:essentials": "bunx turbo run dev --filter=@genfeedai/api --filter=@genfeedai/notifications --concurrency=2",
    "dev:desktop": "bunx turbo run dev --filter=@genfeedai/desktop",
    "dev:docs": "bunx turbo run dev --filter=@genfeedai/docs",
    "dev:frontend": "bunx turbo run dev --filter=@genfeedai/app --filter=@genfeedai/website --concurrency=3",
    "dev:portless:api": "bun run --cwd apps/server/api dev:portless",
    "dev:portless:app": "bun run --cwd apps/app dev:portless",
    "dev:portless:docs": "bun run --cwd apps/docs dev:portless",
    "dev:portless:essentials": "bunx turbo run dev:portless --filter=@genfeedai/api --filter=@genfeedai/notifications --concurrency=2",
    "dev:portless:files": "bun run --cwd apps/server/files dev:portless",
    "dev:portless:frontend": "bunx turbo run dev:portless --filter=@genfeedai/app --filter=@genfeedai/website --concurrency=2",
    "dev:portless:mcp": "bun run --cwd apps/server/mcp dev:portless",
    "dev:portless:notifications": "bun run --cwd apps/server/notifications dev:portless",
    "dev:portless:website": "bun run --cwd apps/website dev:portless",
    "dev:website:fe": "bunx turbo run dev --filter=@genfeedai/website",
    "design:check": "bun run design:lint && bun run check:design-system",
    "design:lint": "bunx @google/design.md lint DESIGN.md",
    "docker:build-all": "docker compose -f docker/docker-compose.yml build",
    "docker:down": "docker compose -f docker/docker-compose.yml down",
    "docker:health": "docker compose -f docker/docker-compose.yml ps",
    "docker:logs": "docker compose -f docker/docker-compose.yml logs -f",
    "docker:up": "docker compose -f docker/docker-compose.yml up -d",
    "env:check": "bun run scripts/env-check.ts",
    "env:sync": "bun run scripts/env-sync.ts",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "bunx turbo run lint",
    "lint-staged": "lint-staged --config lint-staged.config.mjs",
    "sort-modules": "bun scripts/sort-module-arrays.ts",
    "test": "TZ=UTC scripts/sh/sanitize-node-color-env.sh bunx turbo run test",
    "test:cli": "TZ=UTC scripts/sh/sanitize-node-color-env.sh bunx turbo run test --filter=@genfeedai/cli",
    "test:workspace": "TZ=UTC scripts/sh/sanitize-node-color-env.sh vitest run --config vitest.config.ts",
    "test:workspace:watch": "TZ=UTC scripts/sh/sanitize-node-color-env.sh vitest --config vitest.config.ts",
    "test:e2e": "bunx playwright test --config=playwright/configs/playwright.config.ts",
    "test:e2e:core": "bunx playwright test --config=playwright/configs/playwright.config.ts playwright/e2e/tests/smoke playwright/e2e/tests/core --project=app-core",
    "test:e2e:sharded": "node scripts/e2e-sharded.mjs",
    "test:e2e:core:changed": "bunx playwright test --config=playwright/configs/playwright.config.ts playwright/e2e/tests/smoke playwright/e2e/tests/core --project=app-core --only-changed=${E2E_BASE_REF:-origin/develop}",
    "test:e2e:core:failed": "bunx playwright test --config=playwright/configs/playwright.config.ts playwright/e2e/tests/smoke playwright/e2e/tests/core --project=app-core --last-failed",
    "test:e2e:authed": "bunx playwright test --config=playwright/configs/playwright.config.ts --project=app-authed",
    "test:e2e:authed:local": "E2E_AUTHED_LOCAL=1 NEXT_PUBLIC_PLAYWRIGHT_TEST=false bunx playwright test --config=playwright/configs/playwright.config.ts --project=app-authed",
    "test:e2e:authed:failed": "bunx playwright test --config=playwright/configs/playwright.config.ts --project=app-authed --last-failed",
    "test:e2e:smoke": "bunx playwright test --config=playwright/configs/playwright.config.ts playwright/e2e/tests/smoke/all-app-pages.spec.ts --project=app-core",
    "test:e2e:full": "bunx playwright test --config=playwright/configs/playwright-full.config.ts",
    "test:e2e:coverage": "E2E_COVERAGE=1 bunx playwright test --config=playwright/configs/playwright-coverage.config.ts playwright/e2e/tests/smoke playwright/e2e/tests/core",
    "test:e2e:routes": "node scripts/e2e-route-coverage.mjs",
    "test:e2e:release": "bunx playwright test --config=playwright/configs/playwright-release-e2e.config.ts",
    "type-check": "bunx turbo run type-check",
    "type-check:cli": "bunx turbo run type-check --filter=@genfeedai/cli",
    "secretlint": "secretlint '**/*'"
  },
