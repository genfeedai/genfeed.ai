# Genfeed.ai Community Environment Variables
#
# Default Community install is single-user/single-org with no login wall.
# Turn on Better Auth below only when you want local users, passwords,
# magic links, Google sign-in, or team member invites.

# License (leave empty for core-only mode)
GENFEED_LICENSE_KEY=

# GPU Configuration
GENFEED_GPU_URL=http://localhost:8188

# Pricing
GENFEED_MARGIN_MULTIPLIER=1.0

# Database
DATABASE_URL=
REDIS_URL=redis://localhost:6379
POSTGRES_PORT=5432
REDIS_PORT=6379

# Ports
APP_PORT=3000
API_PORT=3010
WEBSITE_PORT=3002
DOCS_PORT=3001
NOTIFICATIONS_PORT=3011
FILES_PORT=3012
WORKERS_PORT=3013
MCP_PORT=3014
CLIPS_PORT=3015
DISCORD_PORT=3016
FANVUE_PORT=3017
SLACK_PORT=3018
TELEGRAM_PORT=3019
IMAGES_PORT=3020
VIDEOS_PORT=3021
VOICES_PORT=3022
LLM_PORT=8000
SELFHOSTED_APP_PORT=3000
SELFHOSTED_API_PORT=3010

# Auth (optional login wall)
BETTER_AUTH_ENABLED=false
NEXT_PUBLIC_BETTER_AUTH_ENABLED=false
# Optional when auth is enabled: the entrypoint will generate and persist one
# under /data/.better-auth-secret if this is empty.
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3010
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# Optional auth providers / transactional email.
# Email/password does not need email delivery. Magic links, password reset,
# email verification, and invites do.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_REPLY_TO_EMAIL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
