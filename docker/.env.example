# Genfeed.ai Environment Variables

# License (leave empty for core-only mode)
GENFEED_LICENSE_KEY=

# GPU Configuration
GENFEED_GPU_URL=http://localhost:8188

# Pricing
GENFEED_MARGIN_MULTIPLIER=1.0

# Database
MONGODB_URI=mongodb://mongo:27017/genfeedai
REDIS_URL=redis://redis:6379

# Auth (optional — for cloud bridge)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
