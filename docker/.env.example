# Genfeed.ai Environment Variables

# License (leave empty for core-only mode)
GENFEED_LICENSE_KEY=

# GPU Configuration
GENFEED_GPU_URL=http://localhost:8188

# Pricing
GENFEED_MARGIN_MULTIPLIER=1.0

# Database
MONGODB_URI=mongodb://mongo:27017/genfeedai
REDIS_URL=redis://redis:6379
MONGODB_PORT=27017
REDIS_PORT=6379

# Ports
APP_PORT=3000
API_PORT=3010
WEBSITE_PORT=3002
DOCS_PORT=3001
NOTIFICATIONS_PORT=3011
FILES_PORT=3012
WORKERS_PORT=3013
MCP_PORT=3014
CLIPS_PORT=3015
DISCORD_PORT=3016
FANVUE_PORT=3017
SLACK_PORT=3018
TELEGRAM_PORT=3019
IMAGES_PORT=3020
VIDEOS_PORT=3021
VOICES_PORT=3022
LLM_PORT=8000
SELFHOSTED_APP_PORT=3000
SELFHOSTED_API_PORT=3010

# Auth (optional — for cloud bridge)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
