# Genfeed.ai Community environment
#
# Community is single-tenant and starts without a login wall. Copy this file to
# docker/.env and add only the optional integrations you use.

# Container image. Release bundles replace latest with the exact release version.
GENFEED_IMAGE_TAG=latest

# Host ports exposed by docker-compose.selfhosted.yml.
SELFHOSTED_APP_PORT=3000
SELFHOSTED_API_PORT=3010
SELFHOSTED_MCP_PORT=3014

# Optional generation providers. Keep keys server-side.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
REPLICATE_KEY=
FAL_API_KEY=
ELEVENLABS_API_KEY=

# Optional local ComfyUI endpoint used by supported API flows. The Community
# image does not start ComfyUI or the separate GPU service workspaces.
DARKROOM_COMFYUI_URL=

# Optional login wall. The entrypoint generates and persists a Better Auth
# secret under /data/.better-auth-secret when BETTER_AUTH_SECRET is empty.
BETTER_AUTH_ENABLED=false
NEXT_PUBLIC_BETTER_AUTH_ENABLED=false
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3010
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:3000

# Optional auth providers and transactional email. Email/password does not need
# delivery; magic links, password resets, verification, and invites do.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_REPLY_TO_EMAIL=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
